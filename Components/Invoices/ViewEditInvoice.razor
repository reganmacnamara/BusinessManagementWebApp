@page "/invoices/{id:long}"
@using System.Text.Json
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities
@using BusinessManagementWebApp.Data.Invoices.DeleteInvoiceItem
@using BusinessManagementWebApp.Data.Invoices.UpdateInvoice
@using BusinessManagementWebApp.Data.Invoices.UpsertInvoiceItem

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (isLoading)
{
    <h1>Fetching Data...</h1>
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
    <MudSkeleton Width="70%" Height="50px" />
}
else
{
    <div class="d-flex">
        <div class="mr-auto p-2">
            <h1>@invoice!.InvoiceRef</h1>
        </div>

        <div class="p-2">
            <MudTooltip Delay="300" Text="Save">
                <MudFab Color="Color.Default"
                        OnClick="OnSave"
                        StartIcon="@Icons.Material.Filled.Save" />
            </MudTooltip>

            <MudTooltip Delay="300" Text="Delete">
                <MudFab Color="Color.Error"
                        OnClick="OnDelete"
                        StartIcon="@Icons.Material.Filled.Delete" />
            </MudTooltip>

            <MudTooltip Delay="300" Text="Cancel">
                <MudFab Color="Color.Error"
                        OnClick="NavigateToInvoices"
                        StartIcon="@Icons.Material.Filled.Cancel" />
            </MudTooltip>
        </div>
    </div>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="Details">
            <MudPaper MaxWidth="70%">
                <MudTextField @bind-Value="invoice.InvoiceDate"
                              Disabled="true"
                              Format="dd/MM/yyyy"
                              Label="Transaction Date"
                              Variant="Variant.Outlined" />

                <MudTextField @bind-Value="invoice.DueDate"
                              Label="Due Date"
                              Format="dd/MM/yyyy"
                              Variant="Variant.Outlined"
                              T="DateTime ?" />

                <MudTextField @bind-Value="invoice.Client.ClientName"
                              Disabled="true"
                              Label="Client Name"
                              Variant="Variant.Outlined" />
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Transaction Items">
            <MudPaper MaxWidth="70%">
                <div class="d-flex justify-content-start">
                    <MudButton Color="Color.Success"
                               OnClick="OpenCreateInvoiceItemDialogAsync"
                               StartIcon="@Icons.Material.Filled.Add">Add Item</MudButton>

                    <MudButton Color="Color.Error"
                               OnClick="DeleteInvoiceItems"
                               StartIcon="@Icons.Material.Filled.Delete">Remove Item</MudButton>
                </div>

                <MudDataGrid @bind-SelectedItems="selectedInvoiceItems"
                             CommittedItemChanges="OnEditInvoiceItem"
                             EditMode="DataGridEditMode.Cell"
                             EditTrigger="DataGridEditTrigger.OnRowClick"
                             Items="@invoiceItems"
                             MultiSelection="true"
                             ReadOnly="false"
                             SelectOnRowClick="false"
                             T="InvoiceItem">

                    <Columns>
                        <SelectColumn T="InvoiceItem" />
                        <PropertyColumn Editable="false"
                                        Property="x => x.Product.ProductCode"
                                        Title="Code" />

                        <PropertyColumn Editable="false"
                                        Property="x => x.Product.ProductName"
                                        Title="Name" />

                        <PropertyColumn Editable="false"
                                        Property="x => x.Product.ProductDescription"
                                        Title="Description" />

                        <PropertyColumn Editable="true"
                                        Property="x => x.Quantity"
                                        Title="Quantity" />

                        <PropertyColumn Editable="true"
                                        Property="x => x.PricePerUnit"
                                        Format="N2"
                                        Title="Each" />

                        <PropertyColumn Editable="false"
                                        Property="x => x.GrossValue"
                                        Format="N2"
                                        Title="Gross" />

                        <PropertyColumn Editable="false"
                                        Property="x => x.TaxValue"
                                        Format="N2"
                                        Title="Tax" />

                        <PropertyColumn Editable="false"
                                        Property="x => x.NetValue"
                                        Format="N2"
                                        Title="Net" />

                    </Columns>

                </MudDataGrid>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>

    <MudMessageBox @ref="deleteConfirmationMessage"
                   Title="Warning"
                   CancelText="Cancel">
        <MessageContent>
            Are you sure you want to delete @(invoice.InvoiceRef)?
        </MessageContent>
        <YesButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
        </YesButton>
    </MudMessageBox>

    <AddInvoiceItemDialog />
}

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private bool isLoading = true;
    private HashSet<InvoiceItem> selectedInvoiceItems = [];
    private Invoice invoice = new();
    private List<InvoiceItem> invoiceItems = [];
    private List<InvoiceItem> invoiceItemsToBeDeleted = [];

    [Parameter]
    public long id { get; set; }

    private void AddInvoiceItem(Product product)
    {
        invoiceItems.Add(new()
        {
            Product = product,
            ProductID = product.ProductID,
            PricePerUnit = product.UnitPrice,
            Quantity = 1,
            GrossValue = product.UnitPrice,
            TaxValue = product.UnitPrice,
            NetValue = product.UnitPrice,
        });
        StateHasChanged();
    }

    private async Task DeleteInvoiceItems()
    {
        if (!selectedInvoiceItems.Any())
            return;

        foreach (var _Item in selectedInvoiceItems)
        {
            invoiceItemsToBeDeleted.Add(_Item);
            invoiceItems.Remove(_Item);
        }

        selectedInvoiceItems.Clear();
        StateHasChanged();
    }

    private async Task GetTranctionData()
    {
        var _Response = await api.GetInvoiceAsync(id);

        invoice = _Response.Invoice;
        invoiceItems = _Response.InvoiceItems;

        isLoading = false;
    }

    private void NavigateToInvoices()
        => NavigationManager.NavigateTo("invoices");

    private async Task OnEditInvoiceItem(InvoiceItem item)
    {
        item.GrossValue = item.PricePerUnit * item.Quantity;
        item.TaxValue = item.GrossValue * (decimal)0.10;
        item.NetValue = item.GrossValue + item.TaxValue;
        StateHasChanged();
    }

    private async Task OnDelete()
    {
        bool? result = await deleteConfirmationMessage.ShowAsync();
        deleteState = result is null ? "Canceled" : "Deleted!";

        if (deleteState == "Deleted!")
        {
            var _Response = await api.DeleteInvoiceAsync(invoice.InvoiceID);
            if (_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{invoice.InvoiceRef} Deleted.", Severity.Warning);
                NavigateToInvoices();
            }
            else
                Snackbar.Add($"Error {(int)_Response.StatusCode}: {_Response.ReasonPhrase}", Severity.Error);
        }
    }

    protected override async Task OnParametersSetAsync()
        => await GetTranctionData();

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(invoice!.InvoiceRef))
        {
            Snackbar.Add("Transaction must have a reference.", Severity.Error);
            return;
        }

        if (invoiceItems.Count == 0)
        {
            Snackbar.Add("Transaction must have at least one item.", Severity.Error);
            return;
        }

        RecalculateTransactionValues();
        var _UpdateTransactionRequest = mapper.Map<UpdateInvoiceRequest>(invoice);
        var _UpdateTransactionResponse = await api.UpdateInvoiceAsync(_UpdateTransactionRequest);

        if (!_UpdateTransactionResponse.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_UpdateTransactionResponse.StatusCode}: {_UpdateTransactionResponse.ReasonPhrase}", Severity.Error);
            return;
        }

        var _ResponseData = Newtonsoft.Json.JsonConvert.DeserializeObject<UpdateInvoiceResponse>(await _UpdateTransactionResponse.Content.ReadAsStringAsync());

        foreach (var _Item in invoiceItems)
        {
            if (_ResponseData is not null && _ResponseData.InvoiceID != 0)
                _Item.InvoiceID = _ResponseData.InvoiceID;

            var _TransactionItemRequest = mapper.Map<UpsertInvoiceItemRequest>(_Item);
            var _TransactionItemResponse = await api.UpsertInvoiceItemAsync(_TransactionItemRequest);

            if (!_TransactionItemResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_TransactionItemResponse.StatusCode}: {_TransactionItemResponse.ReasonPhrase}", Severity.Error);
                return;
            }
        }

        foreach (var _Item in invoiceItemsToBeDeleted)
        {
            var _Response = await api.DeleteInvoiceItemAsync(_Item.InvoiceItemID);
            if (!_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_Response.StatusCode}: {_Response.ReasonPhrase}", Severity.Error);
                return;
            }
        }

        Snackbar.Add("Invoice Updated.", Severity.Success);
        NavigateToInvoices();
    }

    private async Task OpenCreateInvoiceItemDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddInvoiceItemDialog>();

        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            foreach (var _Product in (HashSet<Product>)result.Data)
                AddInvoiceItem(_Product);

            StateHasChanged();
        }
    }

    private void RecalculateTransactionValues()
    {
        invoice.GrossValue = 0;
        invoice.TaxValue = 0;
        invoice.NetValue = 0;

        invoiceItems.ForEach(item => invoice.GrossValue += item.GrossValue);
        invoiceItems.ForEach(item => invoice.TaxValue += item.TaxValue);
        invoiceItems.ForEach(item => invoice.NetValue += item.NetValue);
    }
}