@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IMapper mapper
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Class="mr-3" />
            Add Line Item
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudToggleGroup @bind-Value="lineItemType" T="LineItemType" Color="Color.Primary"
                        Outline="true" Rounded="true" Class="mb-4">
            <MudToggleItem Value="LineItemType.Product">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-1" Size="Size.Small" />
                Product
            </MudToggleItem>
            <MudToggleItem Value="LineItemType.Service">
                <MudIcon Icon="@Icons.Material.Filled.MiscellaneousServices" Class="mr-1" Size="Size.Small" />
                Service
            </MudToggleItem>
        </MudToggleGroup>

        @if (lineItemType == LineItemType.Product)
        {
            <MudDataGrid @bind-SelectedItems="selectedProducts"
                         Breakpoint="Breakpoint.Sm"
                         Hover="true"
                         Items="@products"
                         Loading="@loadingProducts"
                         LoadingProgressColor="Color.Primary"
                         MultiSelection="true"
                         QuickFilter="new Func<Product, bool>(FilterProduct)"
                         RowClass="cursor-pointer">
                <ToolBarContent>
                    <MudTextField @bind-Value="searchString"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="mt-0"
                                  IconSize="Size.Medium"
                                  Placeholder="Search products" />
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="Product" />
                    <PropertyColumn Property="x => x.ProductCode" Title="Code" />
                    <PropertyColumn Property="x => x.ProductName" Title="Name" />
                    <PropertyColumn Property="x => x.ProductDescription" Title="Description" />
                    <PropertyColumn Property="x => x.QuantityOnHand" Title="In Stock" />
                    <PropertyColumn Property="x => x.UnitPrice" Title="Price" Format="C" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Product" />
                </PagerContent>
            </MudDataGrid>
        }
        else
        {
            <MudDataGrid @bind-SelectedItems="selectedServices"
                         Breakpoint="Breakpoint.Sm"
                         Hover="true"
                         Items="@services"
                         Loading="@loadingServices"
                         LoadingProgressColor="Color.Primary"
                         MultiSelection="true"
                         QuickFilter="new Func<Service, bool>(FilterService)"
                         RowClass="cursor-pointer">
                <ToolBarContent>
                    <MudTextField @bind-Value="searchString"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="mt-0"
                                  IconSize="Size.Medium"
                                  Placeholder="Search services" />
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="Service" />
                    <PropertyColumn Property="x => x.ServiceName" Title="Name" />
                    <PropertyColumn Property="x => x.ServiceDescription" Title="Description" />
                    <TemplateColumn Title="Duration">
                        <CellTemplate>
                            @if (context.Item.EstimatedDuration > 0)
                            {
                                <span>@context.Item.EstimatedDuration @context.Item.DurationUnit</span>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.UnitPrice" Title="Price" Format="C" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Service" />
                </PagerContent>
            </MudDataGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Class="px-10"
                   Color="Color.Success"
                   OnClick="OnAdd"
                   Variant="Variant.Filled">
            Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    public enum LineItemType { Product, Service }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private LineItemType lineItemType = LineItemType.Product;
    private string searchString = string.Empty;

    private bool loadingProducts;
    private bool loadingServices;
    private List<Product> products = [];
    private List<Service> services = [];
    private HashSet<Product> selectedProducts = [];
    private HashSet<Service> selectedServices = [];

    protected override async Task OnInitializedAsync()
    {
        loadingProducts = true;
        loadingServices = true;

        var productsTask = api.GetProductsAsync();
        var servicesTask = api.GetServicesAsync();

        await Task.WhenAll(productsTask, servicesTask);

        products = productsTask.Result.Products ?? [];
        services = servicesTask.Result.Services ?? [];

        loadingProducts = false;
        loadingServices = false;
    }

    private bool FilterProduct(Product p)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return p.ProductCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || p.ProductName.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || p.ProductDescription.Contains(searchString, StringComparison.OrdinalIgnoreCase);
    }

    private bool FilterService(Service s)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return s.ServiceName.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || s.ServiceDescription.Contains(searchString, StringComparison.OrdinalIgnoreCase);
    }

    private void OnAdd()
    {
        if (lineItemType == LineItemType.Product)
        {
            if (!selectedProducts.Any())
            {
                Snackbar.Add("Please select at least one product.", Severity.Error);
                return;
            }
            MudDialog.Close(DialogResult.Ok(new InvoiceItemDialogResult(selectedProducts, null)));
        }
        else
        {
            if (!selectedServices.Any())
            {
                Snackbar.Add("Please select at least one service.", Severity.Error);
                return;
            }
            MudDialog.Close(DialogResult.Ok(new InvoiceItemDialogResult(null, selectedServices)));
        }
    }

    public record InvoiceItemDialogResult(
        HashSet<Product>? Products,
        HashSet<Service>? Services);
}
