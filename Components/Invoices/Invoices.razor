@page "/invoices"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities
@using BusinessManagementWebApp.Data.Invoices.DeleteInvoice

@inject ApiClient api
@inject IJSRuntime JS
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="d-flex align-center mb-6">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A;">Invoices</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage and track all client invoices</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2">
            <MudButton Color="Color.Info"
                       Disabled="@(!selectedInvoices.Any())"
                       OnClick="ExportSelectedPdfs"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Variant="Variant.Outlined">Export PDF</MudButton>
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedInvoices.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="NavigateToCreateInvoice"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Invoice</MudButton>
        </MudStack>
    </div>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Total Invoices</MudText>
                    <div class="stat-icon-wrap" style="background: #EFF6FF;">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Style="color: #3B82F6; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #0F172A; line-height: 1;">@invoices.Count</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Unpaid</MudText>
                    <div class="stat-icon-wrap" style="background: #FFFBEB;">
                        <MudIcon Icon="@Icons.Material.Filled.Pending" Style="color: #F59E0B; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #0F172A; line-height: 1;">@invoices.Count(x => x.Outstanding)</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Total Value</MudText>
                    <div class="stat-icon-wrap" style="background: #ECFDF5;">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color: #10B981; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A; line-height: 1;">@invoices.Sum(x => x.NetValue).ToString("C")</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Outstanding Amt.</MudText>
                    <div class="stat-icon-wrap" style="background: #FEF2F2;">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Style="color: #EF4444; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A; line-height: 1;">@invoices.Sum(x => Math.Max(0m, x.NetValue - x.OffsetValue)).ToString("C")</MudText>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedInvoices"
                     Breakpoint="Breakpoint.Sm"
                     Items="invoices"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     RowClass="cursor-pointer"
                     RowClick="InvoiceSelected"
                     SelectOnRowClick="false"
                     T="Invoice">
            <Columns>
                <SelectColumn T="Invoice" />
                <PropertyColumn Property="x => x.InvoiceDate" Title="Date" Format="dd/MM/yyyy" />
                <PropertyColumn Property="x => x.InvoiceRef" Title="Reference" />
                <PropertyColumn Property="x => x.Client.ClientName" Title="Client" />
                <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.Outstanding ? Color.Warning : Color.Success)"
                                 Variant="Variant.Filled">
                            @(context.Item.Outstanding ? "Outstanding" : "Paid")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => Math.Max(0m, x.NetValue - x.OffsetValue)" Title="Outstanding Amt." Format="C" />
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedInvoices.Count > 1
                ? $"{selectedInvoices.Count} Invoices"
                : $"{selectedInvoices.First().InvoiceRef}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private bool loading;
    HashSet<Invoice> selectedInvoices = [];
    List<Invoice> invoices = [];

    private async Task GetTransactionsDataAsync()
    {
        loading = true;
        var _Response = await api.GetInvoicesAsync();
        invoices = _Response.Invoices ?? [];
        loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExportSelectedPdfs()
    {
        foreach (var invoice in selectedInvoices)
        {
            var _Response = await api.ExportInvoicePdfAsync(invoice.InvoiceID);
            if (!_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error exporting {invoice.InvoiceRef}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                continue;
            }
            var bytes = await _Response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadPdf", $"Invoice_{invoice.InvoiceRef}.pdf", bytes);
        }
    }

    private void NavigateToCreateInvoice()
        => NavigationManager.NavigateTo($"/invoices/create");

    private async Task OnDelete()
    {
        if (selectedInvoices.Count != 0)
        {
            int transactionsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var transaction in selectedInvoices)
                {
                    var _Response = await api.DeleteInvoiceAsync(transaction.InvoiceID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        invoices.Remove(transaction);
                        transactionsDeleted++;
                    }
                    else
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                }
            }
            if (transactionsDeleted > 0)
                Snackbar.Add($"{transactionsDeleted} Invoices Deleted.", Severity.Warning);

            selectedInvoices.Clear();
            await GetTransactionsDataAsync();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetTransactionsDataAsync();

    private void InvoiceSelected(DataGridRowClickEventArgs<Invoice> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/invoices/{args.Item.InvoiceID}");
    }
}
