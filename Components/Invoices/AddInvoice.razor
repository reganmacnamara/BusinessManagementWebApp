@page "/invoices/create"
@using System.Text.Json
@using AutoMapper
@using MacsBusinessManagementWebApp.Components.Clients
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities
@using MacsBusinessManagementWebApp.Data.Invoices.CreateInvoice
@using MacsBusinessManagementWebApp.Data.Invoices.UpsertInvoiceItem
@using MacsBusinessManagementWebApp.Infrastructure.Services.Settings

@inject ApiClient api
@inject IMapper mapper
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject UserSettingsService settingsService

<PageTitle>New Invoice</PageTitle>

<div class="page-header">
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <div class="d-flex align-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateToInvoices"
                       Class="mr-2"
                       Style="min-width: 0;">Back</MudButton>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" Style="height: 32px; align-self: center;" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">New Invoice</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Create a new client invoice</MudText>
            </div>
            <MudSpacer />
            <MudButton Color="Color.Primary"
                       OnClick="OnSave"
                       StartIcon="@Icons.Material.Filled.Save"
                       Variant="Variant.Filled">Save</MudButton>
        </div>
    </MudContainer>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">

        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
            <MudPaper Elevation="0" Class="table-card pa-6">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="invoice.InvoiceRef"
                                      Label="Invoice Reference"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Invoice Reference Required" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="invoice.InvoiceDate"
                                       DateChanged="OnInvoiceDateChanged"
                                       Format="dd/MM/yyyy"
                                       Label="Invoice Date"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="invoice.DueDate"
                                       DateChanged="OnDueDateChanged"
                                       Format="dd/MM/yyyy"
                                       Label="Due Date"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="10" sm="5">
                        <MudSelect @key="clients.Count"
                                   Value="invoice.Client"
                                   T="Client"
                                   Label="Client"
                                   Placeholder="Select Client"
                                   ValueChanged="OnClientChanged"
                                   Variant="Variant.Outlined">
                            @foreach (var client in clients)
                            {
                                <MudSelectItem Value="client">@client.ClientName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="2" sm="1" Class="d-flex align-self-end">
                        <MudTooltip Text="Add new client">
                            <MudIconButton Icon="@Icons.Material.Filled.PersonAdd"
                                           Color="Color.Primary"
                                           OnClick="OpenCreateClientDialogAsync" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Line Items" Icon="@Icons.Material.Filled.List">
            <MudPaper Elevation="0" Class="table-card">
                <div class="d-flex align-center pa-3" style="border-bottom: 1px solid #E2E8F0;">
                    <MudButton Color="Color.Primary"
                               OnClick="OpenCreateTransactionItemDialogAsync"
                               StartIcon="@Icons.Material.Filled.Add"
                               Variant="Variant.Filled"
                               Size="Size.Small">Add Item</MudButton>

                    <MudButton Color="Color.Error"
                               OnClick="DeleteTransactionItems"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               Class="ml-2"
                               Disabled="@(!selectedInvoiceItems.Any())">Remove</MudButton>
                </div>
                <MudDataGrid @bind-SelectedItems="selectedInvoiceItems"
                             CommittedItemChanges="OnEditInvoiceItem"
                             EditMode="DataGridEditMode.Cell"
                             EditTrigger="DataGridEditTrigger.OnRowClick"
                             Items="@invoiceItems"
                             MultiSelection="true"
                             ReadOnly="false"
                             SelectOnRowClick="false"
                             T="InvoiceItem">
                    <Columns>
                        <SelectColumn T="InvoiceItem" />
                        <PropertyColumn Editable="false" Property="x => x.Product.ProductCode" Title="Code" />
                        <PropertyColumn Editable="false" Property="x => x.Product.ProductName" Title="Name" />
                        <PropertyColumn Editable="false" Property="x => x.Product.ProductDescription" Title="Description" />
                        <PropertyColumn Editable="false" Property="x => x.Product.QuantityOnHand" Title="In Stock" />
                        <PropertyColumn Editable="true" Property="x => x.Quantity" Title="Quantity" />
                        <PropertyColumn Editable="true" Property="x => x.PricePerUnit" Format="C" Title="Each" />
                        <PropertyColumn Editable="false" Property="x => x.GrossValue" Format="C" Title="Gross" />
                        <PropertyColumn Editable="false" Property="x => x.TaxValue" Format="C" Title="Tax" />
                        <PropertyColumn Editable="false" Property="x => x.NetValue" Format="C" Title="Net" />
                    </Columns>
                </MudDataGrid>
            </MudPaper>
        </MudTabPanel>

    </MudTabs>
</MudContainer>

<AddClientDialog />
<AddInvoiceItemDialog />

@code {
    private List<Client> clients = [];
    private HashSet<InvoiceItem> selectedInvoiceItems = [];
    private Invoice invoice = new();
    private List<InvoiceItem> invoiceItems = [];
    private List<PaymentTerm> paymentTerms = [];

    private void AddTransactionItem(Product product)
    {
        var gross = product.UnitPrice * 1;
        var tax = gross * 0.1m;
        invoiceItems.Add(new()
        {
            Product = product,
            ProductID = product.ProductID,
            PricePerUnit = product.UnitPrice,
            Quantity = 1,
            GrossValue = gross,
            TaxValue = tax,
            NetValue = gross + tax,
        });
        StateHasChanged();
    }

    private void DeleteTransactionItems()
    {
        if (!selectedInvoiceItems.Any())
            return;

        foreach (var _Item in selectedInvoiceItems)
            invoiceItems.Remove(_Item);

        selectedInvoiceItems.Clear();
        StateHasChanged();
    }

    private async Task GetClients()
    {
        var _Response = await api.GetClientsAsync();
        clients = _Response.Clients ?? [];
        this.StateHasChanged();
    }

    private void NavigateToInvoices()
        => NavigationManager.NavigateTo("invoices");

    private async Task OnDueDateChanged(DateTime? dateTime)
    {
        if (!dateTime.HasValue)
            return;

        invoice.DueDate = dateTime.Value;
    }

    private async Task OnEditInvoiceItem(InvoiceItem item)
    {
        item.GrossValue = item.PricePerUnit * item.Quantity;
        item.TaxValue = item.GrossValue * (decimal)0.10;
        item.NetValue = item.GrossValue + item.TaxValue;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await GetClients();

        var _PaymentTermsResponse = await api.GetPaymentTermsAsync();
        paymentTerms = _PaymentTermsResponse.PaymentTerms ?? [];

        invoice.InvoiceDate = DateTime.UtcNow;
        invoice.DueDate = invoice.InvoiceDate.AddDays(30);

        var generatedRef = await settingsService.GenerateInvoiceRefAsync();
        if (!string.IsNullOrEmpty(generatedRef))
            invoice.InvoiceRef = generatedRef;
    }

    private async Task OnInvoiceDateChanged(DateTime? dateTime)
    {
        if (!dateTime.HasValue)
            return;

        invoice.InvoiceDate = dateTime.Value;

        if (invoice.PaymentTerm is not null)
            invoice.DueDate = CalculateDueDate(invoice.InvoiceDate, invoice.PaymentTerm);
    }

    private DateTime CalculateDueDate(DateTime invoiceDate, PaymentTerm term)
    {
        var date = invoiceDate;

        if (term.OffsetFirst)
        {
            date = date.AddDays(term.Days).AddMonths(term.Months);

            if (term.EndOfMonth)
                date = new DateTime(date.Year, date.Month, DateTime.DaysInMonth(date.Year, date.Month));
            else if (term.DayOfMonth.HasValue)
                date = new DateTime(date.Year, date.Month, Math.Min(term.DayOfMonth.Value, DateTime.DaysInMonth(date.Year, date.Month)));
        }
        else
        {
            if (term.EndOfMonth)
                date = new DateTime(date.Year, date.Month, DateTime.DaysInMonth(date.Year, date.Month));
            else if (term.DayOfMonth.HasValue)
                date = new DateTime(date.Year, date.Month, Math.Min(term.DayOfMonth.Value, DateTime.DaysInMonth(date.Year, date.Month)));

            date = date.AddDays(term.Days).AddMonths(term.Months);
        }

        return date;
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(invoice.InvoiceRef))
        {
            Snackbar.Add("Transaction must have a reference.", Severity.Error);
            return;
        }

        if (invoice.Client is null)
        {
            Snackbar.Add("Transaction must have a client.", Severity.Error);
            return;
        }

        if (invoiceItems.Count == 0)
        {
            Snackbar.Add("Transaction must have at least one item.", Severity.Error);
            return;
        }

        RecalculateTransactionValues();

        var _Request = mapper.Map<CreateInvoiceRequest>(invoice);
        var _Response = await api.CreateInvoiceAsync(_Request);

        if (!_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        var _ResponseData = Newtonsoft.Json.JsonConvert.DeserializeObject<CreateInvoiceResponse>(await _Response.Content.ReadAsStringAsync());

        foreach (var _Item in invoiceItems)
        {
            if (_ResponseData is not null && _ResponseData.InvoiceID != 0)
                _Item.InvoiceID = _ResponseData.InvoiceID;

            var _TransactionItemRequest = mapper.Map<UpsertInvoiceItemRequest>(_Item);
            var _TransactionItemResponse = await api.UpsertInvoiceItemAsync(_TransactionItemRequest);

            if (!_TransactionItemResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_TransactionItemResponse.StatusCode}: {await _TransactionItemResponse.GetErrorBodyAsync()}", Severity.Error);
                return;
            }
        }

        await settingsService.IncrementInvoiceNumberAsync();
        Snackbar.Add("Invoice Created.", Severity.Success);
        NavigateToInvoices();
    }

    private async Task OpenCreateClientDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddClientDialog>();
        var result = await dialog.Result;

        if (dialog.Result is not null && !dialog.Result.IsCanceled && result is not null && result.Data is not null)
        {
            SelectCreatedClient((Client)result.Data);
            await GetClients();
            StateHasChanged();
        }
    }

    private void OnClientChanged(Client client)
    {
        invoice.Client = client;
        invoice.ClientID = client.ClientID;

        if (client.PaymentTermID > 0)
        {
            var paymentTerm = client.PaymentTerm
                ?? paymentTerms.FirstOrDefault(pt => pt.PaymentTermID == client.PaymentTermID);

            if (paymentTerm is not null)
            {
                invoice.PaymentTermID = paymentTerm.PaymentTermID;
                invoice.PaymentTerm = paymentTerm;
                invoice.DueDate = CalculateDueDate(invoice.InvoiceDate, paymentTerm);
                StateHasChanged();
            }
        }
    }

    private async Task OpenCreateTransactionItemDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddInvoiceItemDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            foreach (var _Product in (HashSet<Product>)result.Data)
                AddTransactionItem(_Product);

            StateHasChanged();
        }
    }

    private void RecalculateTransactionValues()
    {
        invoice.GrossValue = 0;
        invoice.TaxValue = 0;
        invoice.NetValue = 0;

        invoiceItems.ForEach(item => invoice.GrossValue += item.GrossValue);
        invoiceItems.ForEach(item => invoice.TaxValue += item.TaxValue);
        invoiceItems.ForEach(item => invoice.NetValue += item.NetValue);
    }

    private void SelectCreatedClient(Client client)
    {
        clients.Add(client);
        OnClientChanged(client);
    }
}
