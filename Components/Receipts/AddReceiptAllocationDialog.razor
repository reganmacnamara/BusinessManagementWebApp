@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject ISnackbar Snackbar

<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit"
                     Class="mr-3">

                Add Allocation

            </MudIcon>
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudDataGrid @bind-SelectedItems="selectedInvoices"
                     Items="invoices"
                     MultiSelection="true"
                     ReadOnly="false"
                     SelectOnRowClick="false"
                     T="Invoice">

            <Columns>
                <SelectColumn T="Invoice" />
                <PropertyColumn Editable="false"
                                Property="x => x.InvoiceRef"
                                Title="Ref" />

                <PropertyColumn Editable="false"
                                Property="x => x.InvoiceDate"
                                Title="Date" />

                <PropertyColumn Editable="false"
                                Property="x => x.NetValue"
                                Title="Net"
                                Format="C" />

                <PropertyColumn Editable="false"
                                Property="x => x.OffsetValue"
                                Title="Outstanding"
                                Format="C" />
            </Columns>

        </MudDataGrid>
    </DialogContent>

    <DialogActions>
        <MudButton Class="px-10"
                   Color="Color.Success"
                   OnClick="OnAdd"
                   Variant="Variant.Filled">
            Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private HashSet<Invoice> selectedInvoices = [];
    private List<Invoice> invoices = [];

    [Parameter]
    public long ClientID { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private async Task OnAdd()
    {
        if (selectedInvoices.Count() == 0)
        {
            Snackbar.Add("Please select a Transaction.", Severity.Error);
            return;
        }

        HashSet<ReceiptItem> transactionAllocations = [];
        foreach (var _Transaction in selectedInvoices)
        {
            transactionAllocations.Add(new ReceiptItem()
            {
                InvoiceID = _Transaction.InvoiceID,
                Invoice = _Transaction
            });
        }

        MudDialog.Close(DialogResult.Ok(transactionAllocations));
    }


    // Tech Debt: This should not be returning Receipts, only invoices thus highly inefficient call to API
    // Should be call to recieve paginated Invoices
    // Also should be filtering for only outstanding invoices in API call, not client side
    protected override async Task OnInitializedAsync()
    {
        var _Response = await api.GetClientInvoicesAsync(ClientID);

        invoices = _Response.Invoices
            .Where(t => t.Outstanding == true)
            .ToList() ?? [];

        StateHasChanged();
    }
}