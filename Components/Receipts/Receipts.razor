@page "/receipts"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<div class="d-flex">
    <div class="mr-auto p-2">
        <h1>Receipts</h1>
    </div>
</div>

<div class="d-flex justify-content-start">
    <MudButton Color="Color.Success"
               OnClick="NavigateToCreateReceipt"
               StartIcon="@Icons.Material.Filled.Add">Add Receipt</MudButton>

    <MudButton Color="Color.Error"
               OnClick="OnDelete"
               StartIcon="@Icons.Material.Filled.Delete">Remove Receipts(s)</MudButton>
</div>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="All">
        <MudDataGrid @bind-SelectedItems="selectedReceipts"
                     Breakpoint="Breakpoint.Sm"
                     Items="receipts"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Info"
                     MultiSelection="true"
                     RowClass="cursor-pointer"
                     RowClick="TransactionSelected"
                     SelectOnRowClick="false"
                     T="Receipt">
            <Columns>
                <SelectColumn T="Receipt" />
                <PropertyColumn Property="x => x.ReceiptDate" Title="Date" />
                <PropertyColumn Property="x => x.ReceiptRef" Title="Reference" />
                <PropertyColumn Property="x => x.Client.ClientName" Title="Client" />
                <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                <PropertyColumn Property="x => x.NetValue - x.OffsetValue" Title="Outstanding Amt." Format="C" />
            </Columns>
        </MudDataGrid>
    </MudTabPanel>

</MudTabs>



<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedReceipts.Count > 1
                ? $"{selectedReceipts.Count} Receipts"
                : $"{selectedReceipts.First().ReceiptRef}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private bool loading;
    HashSet<Receipt> selectedReceipts = [];
    List<Receipt> receipts = [];

    private async Task GetTransactionsDataAsync()
    {
        loading = true;

        var _Response = await api.GetReceiptsAsync();
        receipts = _Response.Receipts ?? [];

        loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void NavigateToCreateReceipt()
        => NavigationManager.NavigateTo($"/receipts/create");

    private async Task OnDelete()
    {
        if (selectedReceipts.Count != 0)
        {
            int transactionsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var transaction in selectedReceipts)
                {
                    var _Response = await api.DeleteReceiptAsync(transaction.ReceiptID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        receipts.Remove(transaction);
                        transactionsDeleted++;
                    }
                    else
                    {
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {_Response.ReasonPhrase}", Severity.Error);
                        return;
                    }
                }
            }
            if (transactionsDeleted > 0)
                Snackbar.Add($"{transactionsDeleted} Receipts Deleted.", Severity.Warning);

            selectedReceipts.Clear();
            await GetTransactionsDataAsync();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetTransactionsDataAsync();

    private void TransactionSelected(DataGridRowClickEventArgs<Receipt> args)
    {
        var _SelectedTransaction = args.Item;

        if (_SelectedTransaction is not null)
            NavigationManager.NavigateTo($"/receipts/{_SelectedTransaction.ReceiptID}");
    }
}
