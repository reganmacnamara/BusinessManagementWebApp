@page "/receipts"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IJSRuntime JS
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="d-flex align-center mb-6">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A;">Receipts</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track all payments received from clients</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2">
            <MudButton Color="Color.Info"
                       Disabled="@(!selectedReceipts.Any())"
                       OnClick="ExportSelectedPdfs"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Variant="Variant.Outlined">Export PDF</MudButton>
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedReceipts.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="NavigateToCreateReceipt"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Receipt</MudButton>
        </MudStack>
    </div>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Total Receipts</MudText>
                    <div class="stat-icon-wrap" style="background: #EFF6FF;">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Style="color: #3B82F6; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #0F172A; line-height: 1;">@receipts.Count</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Total Received</MudText>
                    <div class="stat-icon-wrap" style="background: #ECFDF5;">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color: #10B981; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A; line-height: 1;">@receipts.Sum(x => x.NetValue).ToString("C")</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Unallocated</MudText>
                    <div class="stat-icon-wrap" style="background: #FFFBEB;">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="color: #F59E0B; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A; line-height: 1;">@receipts.Sum(x => Math.Max(0m, x.NetValue - x.OffsetValue)).ToString("C")</MudText>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedReceipts"
                     Breakpoint="Breakpoint.Sm"
                     Items="receipts"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     RowClass="cursor-pointer"
                     RowClick="TransactionSelected"
                     SelectOnRowClick="false"
                     T="Receipt">
            <Columns>
                <SelectColumn T="Receipt" />
                <PropertyColumn Property="x => x.ReceiptDate" Title="Date" Format="dd/MM/yyyy" />
                <PropertyColumn Property="x => x.ReceiptRef" Title="Reference" />
                <PropertyColumn Property="x => x.Client.ClientName" Title="Client" />
                <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.Outstanding ? Color.Warning : Color.Success)"
                                 Variant="Variant.Filled">
                            @(context.Item.Outstanding ? "Unallocated" : "Allocated")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => Math.Max(0m, x.NetValue - x.OffsetValue)" Title="Outstanding Amt." Format="C" />
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedReceipts.Count > 1
                ? $"{selectedReceipts.Count} Receipts"
                : $"{selectedReceipts.First().ReceiptRef}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private bool loading;
    HashSet<Receipt> selectedReceipts = [];
    List<Receipt> receipts = [];

    private async Task GetTransactionsDataAsync()
    {
        loading = true;
        var _Response = await api.GetReceiptsAsync();
        receipts = _Response.Receipts ?? [];
        loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExportSelectedPdfs()
    {
        foreach (var receipt in selectedReceipts)
        {
            var _Response = await api.ExportReceiptPdfAsync(receipt.ReceiptID);
            if (!_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error exporting {receipt.ReceiptRef}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                continue;
            }
            var bytes = await _Response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadPdf", $"Receipt_{receipt.ReceiptRef}.pdf", bytes);
        }
    }

    private void NavigateToCreateReceipt()
        => NavigationManager.NavigateTo($"/receipts/create");

    private async Task OnDelete()
    {
        if (selectedReceipts.Count != 0)
        {
            int transactionsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var transaction in selectedReceipts)
                {
                    var _Response = await api.DeleteReceiptAsync(transaction.ReceiptID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        receipts.Remove(transaction);
                        transactionsDeleted++;
                    }
                    else
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                }
            }
            if (transactionsDeleted > 0)
                Snackbar.Add($"{transactionsDeleted} Receipts Deleted.", Severity.Warning);

            selectedReceipts.Clear();
            await GetTransactionsDataAsync();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetTransactionsDataAsync();

    private void TransactionSelected(DataGridRowClickEventArgs<Receipt> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/receipts/{args.Item.ReceiptID}");
    }
}
