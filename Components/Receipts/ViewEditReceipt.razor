@page "/receipts/{id:long}"
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities
@using BusinessManagementWebApp.Data.Receipts.DeleteReceiptItem
@using BusinessManagementWebApp.Data.Receipts.UpdateReceipt
@using BusinessManagementWebApp.Data.Receipts.UpsertReceiptItem

@inject ApiClient api
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudSkeleton Height="48px" Class="mb-2" Style="border-radius: 8px;" />
        <MudSkeleton Height="20px" Width="40%" Class="mb-6" Style="border-radius: 8px;" />
        <MudSkeleton Height="300px" Style="border-radius: 12px;" />
    </MudContainer>
}
else
{
    <div class="page-header">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <div class="d-flex align-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateToReceipts"
                       Class="mr-2"
                       Style="min-width: 0;">Back</MudButton>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" Style="height: 32px; align-self: center;" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">@receipt!.ReceiptRef</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@receipt.Client?.ClientName</MudText>
            </div>
            <MudSpacer />
            <MudStack Row="true" Spacing="2">
                <MudButton Color="Color.Info"
                           OnClick="ExportPdf"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           Variant="Variant.Outlined">Export PDF</MudButton>
                <MudButton Color="Color.Primary"
                           OnClick="OnSave"
                           StartIcon="@Icons.Material.Filled.Save"
                           Variant="Variant.Filled">Save</MudButton>
                <MudButton Color="Color.Error"
                           OnClick="OnDelete"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Variant="Variant.Outlined">Delete</MudButton>
            </MudStack>
        </div>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">

            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
                <MudPaper Elevation="0" Class="table-card pa-6">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="receipt.ReceiptRef"
                                          Label="Receipt Reference"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Receipt Reference Required" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker @bind-Date="receipt.ReceiptDate"
                                           Format="dd/MM/yyyy"
                                           Label="Receipt Date"
                                           Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Value="receipt.Client?.ClientName"
                                          Disabled="true"
                                          Label="Client"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField Format="C"
                                             Label="Gross Value"
                                             T="decimal"
                                             Value="receipt.GrossValue"
                                             ValueChanged="OnGrossValueChanged"
                                             Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField Format="C"
                                             Label="Tax Value"
                                             T="decimal"
                                             Value="receipt.TaxValue"
                                             ValueChanged="OnTaxValueChanged"
                                             Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField Format="C"
                                             Label="Net Value"
                                             T="decimal"
                                             Value="receipt.NetValue"
                                             ValueChanged="OnNetValueChanged"
                                             Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Allocations" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                <MudPaper Elevation="0" Class="table-card">
                    <div class="d-flex align-center pa-3" style="border-bottom: 1px solid #E2E8F0;">
                        <MudButton Color="Color.Primary"
                                   OnClick="OpenAddAllocationDialogAsync"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Variant="Variant.Filled"
                                   Size="Size.Small">Add Item</MudButton>
                        <MudButton Color="Color.Error"
                                   OnClick="RemoveSelectedItems"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Class="ml-2"
                                   Disabled="@(!selectedReceiptItems.Any())">Remove</MudButton>
                        <MudSpacer />
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mr-2">Un-Allocated:</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@Math.Max(0m, receipt.NetValue - receipt.OffsetValue).ToString("C")</MudText>
                    </div>
                    <MudDataGrid @bind-SelectedItems="selectedReceiptItems"
                                 Items="receiptItems"
                                 EditMode="DataGridEditMode.Cell"
                                 EditTrigger="DataGridEditTrigger.OnRowClick"
                                 MultiSelection="true"
                                 ReadOnly="false"
                                 SelectOnRowClick="false"
                                 T="ReceiptItem">
                        <Columns>
                            <SelectColumn T="ReceiptItem" />
                            <PropertyColumn Editable="false"
                                            Property="x => x.Invoice.InvoiceRef"
                                            Title="Ref" />
                            <PropertyColumn Editable="false"
                                            Property="x => x.Invoice.InvoiceDate"
                                            Title="Date"
                                            Format="dd/MM/yyyy" />
                            <PropertyColumn Editable="false"
                                            Property="x => x.Invoice.NetValue"
                                            Title="Net"
                                            Format="C" />
                            <PropertyColumn Editable="false"
                                            Property="x => Math.Max(0m, x.Invoice.NetValue - x.Invoice.OffsetValue - x.NetValue)"
                                            Title="Outstanding Amt."
                                            Format="C" />
                            <TemplateColumn Editable="true" Title="Allocated">
                                <CellTemplate>
                                    @context.Item.NetValue.ToString("C")
                                </CellTemplate>
                                <EditTemplate>
                                    <MudNumericField Format="C"
                                                     Value="context.Item.NetValue"
                                                     ValueChanged="(value) => OnAllocationUpdated(value, context.Item)"
                                                     T="decimal" />
                                </EditTemplate>
                            </TemplateColumn>
                            <TemplateColumn>
                                <CellTemplate>
                                    <MudStack Row="true">
                                        <MudButton Color="Color.Success"
                                                   OnClick="() => CompleteAllocation(context.Item)"
                                                   Size="Size.Small"
                                                   Variant="Variant.Filled">
                                            Allocate
                                        </MudButton>
                                        <MudButton Color="Color.Warning"
                                                   OnClick="() => ClearAllocation(context.Item)"
                                                   Size="Size.Small"
                                                   Variant="Variant.Filled">
                                            De-Allocate
                                        </MudButton>
                                    </MudStack>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                </MudPaper>
            </MudTabPanel>

        </MudTabs>
    </MudContainer>

    <MudMessageBox @ref="deleteConfirmationMessage"
                   Title="Warning"
                   CancelText="Cancel">
        <MessageContent>
            Are you sure you want to delete @(receipt.ReceiptRef)?
        </MessageContent>
        <YesButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
        </YesButton>
    </MudMessageBox>

    <AddReceiptAllocationDialog />
}

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private bool isLoading = true;
    private Receipt receipt = new();
    private List<ReceiptItem> receiptItems = [];
    private List<ReceiptItem> receiptItemsToDelete = [];
    private HashSet<ReceiptItem> selectedReceiptItems = [];

    [Parameter]
    public long id { get; set; }

    protected override async Task OnParametersSetAsync()
        => await LoadReceiptDataAsync();

    private async Task LoadReceiptDataAsync()
    {
        var _Response = await api.GetReceiptAsync(id);
        receipt = _Response.Receipt;
        receiptItems = _Response.ReceiptItems;
        isLoading = false;
    }

    private async Task ExportPdf()
    {
        var _Response = await api.ExportReceiptPdfAsync(receipt.ReceiptID);
        if (!_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        var bytes = await _Response.Content.ReadAsByteArrayAsync();
        await JS.InvokeVoidAsync("downloadPdf", $"Receipt_{receipt.ReceiptRef}.pdf", bytes);
    }

    private void NavigateToReceipts()
        => NavigationManager.NavigateTo("receipts");

    private void ClearAllocation(ReceiptItem allocation)
    {
        allocation.NetValue = 0;
        RecalculateOffsets();
        StateHasChanged();
    }

    private void CompleteAllocation(ReceiptItem allocation)
    {
        var invoiceRemaining = allocation.Invoice.NetValue - allocation.Invoice.OffsetValue + allocation.NetValue;
        var receiptAvailable = receipt.NetValue - receipt.OffsetValue + allocation.NetValue;
        allocation.NetValue = Math.Min(invoiceRemaining, receiptAvailable);
        RecalculateOffsets();
        StateHasChanged();
    }

    private void OnAllocationUpdated(decimal value, ReceiptItem item)
    {
        var invoiceRemaining = item.Invoice.NetValue - item.Invoice.OffsetValue + item.NetValue;
        var receiptAvailable = receipt.NetValue - receipt.OffsetValue + item.NetValue;
        var maxAllowable = Math.Min(invoiceRemaining, receiptAvailable);
        if (value >= 0 && value <= maxAllowable)
        {
            item.NetValue = value;
            RecalculateOffsets();
            StateHasChanged();
        }
    }

    private void RecalculateOffsets()
        => receipt.OffsetValue = receiptItems.Sum(a => a.NetValue);

    private async Task RemoveSelectedItems()
    {
        if (!selectedReceiptItems.Any())
            return;

        foreach (var item in selectedReceiptItems)
        {
            if (item.ReceiptItemID != 0)
                receiptItemsToDelete.Add(item);

            receiptItems.Remove(item);
        }

        selectedReceiptItems.Clear();
        RecalculateOffsets();
        StateHasChanged();
    }

    private async Task OpenAddAllocationDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddReceiptAllocationDialog>("", new DialogParameters<AddReceiptAllocationDialog>()
        {
            { x => x.ClientID, receipt.ClientID }
        });

        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            foreach (var allocation in (HashSet<ReceiptItem>)result.Data)
                receiptItems.Add(allocation);

            RecalculateOffsets();
            StateHasChanged();
        }
    }

    private void OnGrossValueChanged(decimal value)
    {
        receipt.GrossValue = value;
        receipt.TaxValue = value * 0.1m;
        receipt.NetValue = receipt.GrossValue + receipt.TaxValue;
    }

    private void OnNetValueChanged(decimal value)
    {
        receipt.NetValue = value;
        receipt.GrossValue = receipt.NetValue / 1.1m;
        receipt.TaxValue = receipt.GrossValue * 0.1m;
    }

    private void OnTaxValueChanged(decimal value)
    {
        receipt.TaxValue = value;
        receipt.GrossValue = receipt.TaxValue * 10;
        receipt.NetValue = receipt.GrossValue + receipt.TaxValue;
    }

    private async Task OnDelete()
    {
        bool? result = await deleteConfirmationMessage.ShowAsync();
        if (result is null) return;

        var _Response = await api.DeleteReceiptAsync(receipt.ReceiptID);
        if (_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"{receipt.ReceiptRef} Deleted.", Severity.Warning);
            NavigateToReceipts();
        }
        else
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(receipt.ReceiptRef))
        {
            Snackbar.Add("Receipt must have a reference.", Severity.Error);
            return;
        }

        RecalculateOffsets();
        receipt.Outstanding = receipt.OffsetValue < receipt.NetValue;

        var _UpdateResponse = await api.UpdateReceiptAsync(mapper.Map<UpdateReceiptRequest>(receipt));
        if (!_UpdateResponse.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_UpdateResponse.StatusCode}: {await _UpdateResponse.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        foreach (var item in receiptItems)
        {
            var _UpsertRequest = mapper.Map<UpsertReceiptItemRequest>(item);
            _UpsertRequest.ReceiptID = receipt.ReceiptID;

            var _UpsertResponse = await api.UpsertReceiptItemAsync(_UpsertRequest);
            if (!_UpsertResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_UpsertResponse.StatusCode}: {await _UpsertResponse.GetErrorBodyAsync()}", Severity.Error);
                return;
            }
        }

        foreach (var item in receiptItemsToDelete)
        {
            var _DeleteResponse = await api.DeleteReceiptItemAsync(item.ReceiptItemID);
            if (!_DeleteResponse.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_DeleteResponse.StatusCode}: {await _DeleteResponse.GetErrorBodyAsync()}", Severity.Error);
                return;
            }
        }

        Snackbar.Add("Receipt Updated.", Severity.Success);
        NavigateToReceipts();
    }
}
