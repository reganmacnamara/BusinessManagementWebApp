@inherits LayoutComponentBase
@using MacsBusinessManagementWebApp.Infrastructure.Services.Auth
@inject AuthTokenService tokenService
@inject NavigationManager NavigationManager

<MudThemeProvider Theme="_theme" />

<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Medium"
                   CloseButton="true"
                   Position="DialogPosition.Center"
                   CloseOnEscapeKey="true" />

<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="DrawerToggle" />
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight: 700; letter-spacing: -0.3px;">
            Mac's Business Manager
        </MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Inherit"
                       OnClick="NavigateToOptions"
                       Title="Options" />
        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit"
                       OnClick="Logout"
                       Title="Sign Out" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="0"
               Breakpoint="Breakpoint.Md"
               Variant="DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <MudContainer MaxWidth="MaxWidth.Medium" Class="pa-6">
                    <MudPaper Elevation="0" Class="pa-10 d-flex flex-column align-center"
                              Style="border:1px solid #FEE2E2; border-radius:12px; background:#FFF5F5; text-align:center;">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline"
                                 Style="color:#EF4444; font-size:3.5rem;" Class="mb-3" />
                        <MudText Typo="Typo.h5" Style="color:#991B1B; font-weight:700;" Class="mb-2">
                            An unexpected error occurred
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5" Style="max-width:520px;">
                            @ex.Message
                        </MudText>
                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="@(() => _errorBoundary?.Recover())">
                            Recover
                        </MudButton>
                    </MudPaper>
                </MudContainer>
            </ErrorContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3B82F6",
            PrimaryContrastText = "#FFFFFF",
            PrimaryDarken = "#1D4ED8",
            PrimaryLighten = "#93C5FD",
            Secondary = "#8B5CF6",
            SecondaryContrastText = "#FFFFFF",
            AppbarBackground = "#0F172A",
            AppbarText = "#F1F5F9",
            DrawerBackground = "#0F172A",
            DrawerText = "#94A3B8",
            DrawerIcon = "#94A3B8",
            Background = "#F1F5F9",
            Surface = "#FFFFFF",
            Success = "#10B981",
            SuccessContrastText = "#FFFFFF",
            Warning = "#F59E0B",
            WarningContrastText = "#FFFFFF",
            Error = "#EF4444",
            ErrorContrastText = "#FFFFFF",
            Info = "#06B6D4",
            InfoContrastText = "#FFFFFF",
            TextPrimary = "#0F172A",
            TextSecondary = "#64748B",
            TextDisabled = "#94A3B8",
            ActionDefault = "#64748B",
            Divider = "#E2E8F0",
            TableLines = "#E2E8F0",
            TableHover = "#F8FAFC",
            LinesDefault = "#E2E8F0",
            LinesInputs = "#CBD5E1",
            OverlayDark = "rgba(0,0,0,0.5)",
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
            DrawerWidthLeft = "256px",
            AppbarHeight = "64px",
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!tokenService.IsAuthenticated)
            NavigationManager.NavigateTo("/login");
        else if (!tokenService.HasCompany)
            NavigationManager.NavigateTo("/register-company");
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private void NavigateToOptions() => NavigationManager.NavigateTo("/options");

    private void Logout()
    {
        tokenService.ClearToken();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
