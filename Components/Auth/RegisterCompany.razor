@page "/register-company"
@layout MacsBusinessManagementWebApp.Components.Layout.EmptyLayout
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Companies.RegisterCompany
@using MacsBusinessManagementWebApp.Infrastructure.Services.Auth
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api
@inject AuthTokenService tokenService
@inject NavigationManager NavigationManager

<PageTitle>Register Company — Mac's Business Manager</PageTitle>

<MudThemeProvider Theme="_theme" />

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);">
    <MudPaper Elevation="4" Style="width: 100%; max-width: 520px; border-radius: 16px; overflow: hidden;">

        <div style="background: #0F172A; padding: 32px 32px 24px; text-align: center;">
            <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size: 2.5rem; color: #3B82F6;" />
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #F1F5F9; margin-top: 8px;">
                Register Your Company
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 4px;">
                Set up your company to get started
            </MudText>
        </div>

        <div style="padding: 32px;">
            <MudForm @ref="form">
                <MudTextField @bind-Value="request.CompanyName"
                              Label="Company Name"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Business"
                              Required="true"
                              RequiredError="Company name is required"
                              Class="mb-3" />

                <MudTextField @bind-Value="request.CompanyABN"
                              Label="ABN"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudTextField @bind-Value="request.Email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Class="mb-3" />

                <MudTextField @bind-Value="request.Phone"
                              Label="Phone"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Phone"
                              Class="mb-3" />

                <MudTextField @bind-Value="request.AddressLine1"
                              Label="Address Line 1"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudTextField @bind-Value="request.AddressLine2"
                              Label="Address Line 2"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudGrid Spacing="2" Class="mb-3">
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="request.State"
                                      Label="State"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="request.PostCode"
                                      Label="Postcode"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="request.Country"
                                      Label="Country"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@errorMessage</MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="font-weight: 600; text-transform: none; border-radius: 8px; height: 48px;"
                           Disabled="@isLoading"
                           OnClick="OnSubmit">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                    }
                    Register Company
                </MudButton>
            </MudForm>
        </div>
    </MudPaper>
</div>

@code {
    private MudForm form = default!;
    private RegisterCompanyRequest request = new();
    private string errorMessage = string.Empty;
    private bool isLoading;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3B82F6",
            PrimaryContrastText = "#FFFFFF",
        }
    };

    protected override void OnInitialized()
    {
        if (!tokenService.IsAuthenticated)
            NavigationManager.NavigateTo("/login");
    }

    private async Task OnSubmit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var response = await api.RegisterCompanyAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegisterCompanyResponse>();
                if (result?.Token is not null)
                {
                    tokenService.SetToken(result.Token, result.Expiry);
                    NavigationManager.NavigateTo("/", forceLoad: true);
                }
                else
                {
                    errorMessage = "Invalid response from server.";
                }
            }
            else
            {
                errorMessage = await response.GetErrorBodyAsync();
            }
        }
        catch (Exception)
        {
            errorMessage = "Unable to connect to the server. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
