@page "/payment-terms"
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject ISnackbar Snackbar

<PageTitle>Payment Terms</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="d-flex align-center mb-6">
        <div>
            <MudText Typo="Typo.h5" Class="page-title">Payment Terms</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Configure payment terms for client invoices</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2">
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedTerms.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="OpenCreateDialogAsync"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Payment Term</MudButton>
        </MudStack>
    </div>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #FFF7ED;">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="color: #F97316; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Total Payment Terms</MudText>
                        <MudText Typo="Typo.h4" Class="stat-value">@paymentTerms.Count</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedTerms"
                     Breakpoint="Breakpoint.Sm"
                     Items="@paymentTerms"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     SelectOnRowClick="false"
                     T="PaymentTerm">
            <Columns>
                <SelectColumn T="PaymentTerm" />
                <PropertyColumn Property="x => x.PaymentTermName" Title="Name" />
                <PropertyColumn Property="x => x.Days" Title="Days" />
                <PropertyColumn Property="x => x.Months" Title="Months" />
                <TemplateColumn Title="End of Month">
                    <CellTemplate>
                        <MudIcon Icon="@(context.Item.EndOfMonth ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                 Color="@(context.Item.EndOfMonth ? Color.Success : Color.Default)"
                                 Size="Size.Small" />
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.DayOfMonth" Title="Day of Month" />
                <TemplateColumn Title="Offset First">
                    <CellTemplate>
                        <MudIcon Icon="@(context.Item.OffsetFirst ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                 Color="@(context.Item.OffsetFirst ? Color.Success : Color.Default)"
                                 Size="Size.Small" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedTerms.Count > 1
                ? $"{selectedTerms.Count} Payment Terms"
                : $"{selectedTerms.First().PaymentTermName}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private bool loading;
    private List<PaymentTerm> paymentTerms = [];
    private HashSet<PaymentTerm> selectedTerms = [];

    private async Task GetPaymentTerms()
    {
        loading = true;
        var _Response = await api.GetPaymentTermsAsync();
        paymentTerms = _Response.PaymentTerms ?? [];
        loading = false;
        StateHasChanged();
    }

    private async Task OnDelete()
    {
        if (selectedTerms.Count != 0)
        {
            int termsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var term in selectedTerms)
                {
                    var _Response = await api.DeletePaymentTermAsync(term.PaymentTermID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        paymentTerms.Remove(term);
                        termsDeleted++;
                    }
                    else
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                }
            }

            if (termsDeleted > 0)
                Snackbar.Add($"{termsDeleted} Payment Terms Deleted.", Severity.Warning);

            await GetPaymentTerms();
            selectedTerms.Clear();
            StateHasChanged();
        }
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddPaymentTermDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            paymentTerms.Add((PaymentTerm)result.Data);
            await GetPaymentTerms();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetPaymentTerms();
}
