@page "/clients/{id:long}"
@using System.Text.Json
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Clients.DeleteClient
@using MacsBusinessManagementWebApp.Data.Clients.UpdateClient
@using MacsBusinessManagementWebApp.Components.PaymentTerms
@using MacsBusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudSkeleton Height="48px" Class="mb-2" Style="border-radius: 8px;" />
        <MudSkeleton Height="20px" Width="40%" Class="mb-6" Style="border-radius: 8px;" />
        <MudSkeleton Height="300px" Style="border-radius: 12px;" />
    </MudContainer>
}
else
{
    <div class="page-header">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <div class="d-flex align-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateToClients"
                       Class="mr-2"
                       Style="min-width: 0;">Back</MudButton>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" Style="height: 32px; align-self: center;" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">@client!.ClientName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Client Details</MudText>
            </div>
            <MudSpacer />
            <MudStack Row="true" Spacing="2">
                <MudButton Color="Color.Primary"
                           OnClick="OnSave"
                           StartIcon="@Icons.Material.Filled.Save"
                           Variant="Variant.Filled">Save</MudButton>
                <MudButton Color="Color.Error"
                           OnClick="OnDelete"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Variant="Variant.Outlined">Delete</MudButton>
            </MudStack>
        </div>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">

            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Person">
                <MudPaper Elevation="0" Class="table-card pa-6">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.ClientName"
                                          Label="Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Client Name Required" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.ClientEmail" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email" Validation="@(new Func<string, string?>(ValidateEmail))" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.ClientPhone" Label="Phone" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.ClientMobile" Label="Mobile" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.AddressLine1" Label="Address Line 1" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="client.AddressLine2" Label="Address Line 2" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="client.PostCode" Label="Postcode" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="client.State" Label="State" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="client.Country" Label="Country" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="client.ReminderIntervalDays" Label="Reminder Interval (Days)" Variant="Variant.Outlined" Min="0" />
                        </MudItem>
                        <MudItem xs="10" sm="5">
                            <MudSelect @key="paymentTerms.Count"
                                       Value="client.PaymentTerm"
                                       T="PaymentTerm"
                                       Label="Payment Term"
                                       Placeholder="Select Payment Term"
                                       ValueChanged="OnPaymentTermChanged"
                                       Variant="Variant.Outlined">
                                @foreach (var pt in paymentTerms)
                                {
                                    <MudSelectItem Value="pt">@pt.PaymentTermName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="2" sm="1" Class="d-flex align-self-end">
                            <MudTooltip Text="Add new payment term">
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Color="Color.Primary"
                                               OnClick="OpenCreatePaymentTermDialogAsync" />
                            </MudTooltip>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Invoices" Icon="@Icons.Material.Filled.Description">
                <MudPaper Elevation="0" Class="table-card">
                    <MudDataGrid Breakpoint="Breakpoint.Sm"
                                 Items="invoices"
                                 Hover="true"
                                 RowClass="cursor-pointer"
                                 RowClick="InvoiceSelected"
                                 T="Invoice">
                        <Columns>
                            <PropertyColumn Property="x => x.InvoiceDate" Title="Date" Format="dd/MM/yyyy" />
                            <PropertyColumn Property="x => x.InvoiceRef" Title="Reference" />
                            <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                            <TemplateColumn Title="Status">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.Item.Outstanding ? Color.Warning : Color.Success)"
                                             Variant="Variant.Filled">
                                        @(context.Item.Outstanding ? "Outstanding" : "Paid")
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => Math.Max(0m, x.NetValue - x.OffsetValue)" Title="Outstanding Amt." Format="C" />
                        </Columns>
                    </MudDataGrid>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Receipts" Icon="@Icons.Material.Filled.Payments">
                <MudPaper Elevation="0" Class="table-card">
                    <MudDataGrid Breakpoint="Breakpoint.Sm"
                                 Items="receipts"
                                 Hover="true"
                                 RowClass="cursor-pointer"
                                 RowClick="ReceiptSelected"
                                 T="Receipt">
                        <Columns>
                            <PropertyColumn Property="x => x.ReceiptDate" Title="Date" Format="dd/MM/yyyy" />
                            <PropertyColumn Property="x => x.ReceiptRef" Title="Reference" />
                            <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                            <PropertyColumn Property="x => Math.Max(0m, x.NetValue - x.OffsetValue)" Title="Outstanding Amt." Format="C" />
                        </Columns>
                    </MudDataGrid>
                </MudPaper>
            </MudTabPanel>

        </MudTabs>
    </MudContainer>
}

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(client.ClientName)?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private Client client = default!;
    private MudMessageBox deleteConfirmationMessage = default!;
    private string deleteState = string.Empty;
    private List<Invoice> invoices = [];
    private bool isLoading = true;
    private List<PaymentTerm> paymentTerms = [];
    private List<Receipt> receipts = [];

    [Parameter]
    public long id { get; set; }

    private async Task GetClientData()
    {
        var _Client = await api.GetClientAsync(id);
        var _ClientInvoices = await api.GetClientInvoicesAsync(id);
        var _ClientReceipts = await api.GetClientReceiptsAsync(id);
        var _PaymentTerms = await api.GetPaymentTermsAsync();

        client = _Client.Client;
        invoices = _ClientInvoices.Invoices;
        receipts = _ClientReceipts.Receipts;
        paymentTerms = _PaymentTerms.PaymentTerms ?? [];

        if (client.PaymentTermID.HasValue)
            client.PaymentTerm = paymentTerms.FirstOrDefault(pt => pt.PaymentTermID == client.PaymentTermID.Value);
    }

    private static string? ValidateEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (!new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(value))
            return "Invalid email address.";

        return null;
    }

    private void OnPaymentTermChanged(PaymentTerm paymentTerm)
    {
        client.PaymentTerm = paymentTerm;
        client.PaymentTermID = paymentTerm?.PaymentTermID;
    }

    private async Task OpenCreatePaymentTermDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddPaymentTermDialog>();
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is not null)
        {
            var newPaymentTerm = (PaymentTerm)result.Data;
            paymentTerms.Add(newPaymentTerm);
            client.PaymentTerm = newPaymentTerm;
            client.PaymentTermID = newPaymentTerm.PaymentTermID;
            StateHasChanged();
        }
    }

    private void InvoiceSelected(DataGridRowClickEventArgs<Invoice> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/invoices/{args.Item.InvoiceID}");
    }

    private void NavigateToClients()
        => NavigationManager.NavigateTo("clients");

    private async Task OnDelete()
    {
        bool? result = await deleteConfirmationMessage.ShowAsync();
        deleteState = result is null ? "Canceled" : "Deleted!";

        if (deleteState == "Deleted!")
        {
            var _Response = await api.DeleteClientAsync(client.ClientID);
            if (_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{client.ClientName} Deleted.", Severity.Warning);
                NavigateToClients();
            }
            else
                Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await GetClientData();
        isLoading = false;
        this.StateHasChanged();
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(client!.ClientName))
        {
            Snackbar.Add("Client must have a name.", Severity.Error);
            return;
        }

        var _Request = mapper.Map<UpdateClientRequest>(client);
        var _Response = await api.UpdateClientAsync(_Request);

        if (!_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        Snackbar.Add("Client Updated.", Severity.Success);
        NavigationManager.NavigateTo("clients");
    }

    private void ReceiptSelected(DataGridRowClickEventArgs<Receipt> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/receipts/{args.Item.ReceiptID}");
    }
}
