@using System.Text.Json
@using AutoMapper
@using MacsBusinessManagementWebApp.Components.PaymentTerms
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Clients.CreateClient
@using MacsBusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" /> Create Client
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="client.ClientName" Label="Name" Variant="Variant.Outlined" Required="true" RequiredError="Client Name Required"></MudTextField>
        <MudTextField @bind-Value="client.ClientEmail" Label="Email" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.ClientPhone" Label="Phone" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.ClientMobile" Label="Mobile" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.AddressLine1" Label="Address Line 1" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.AddressLine2" Label="Address Line 2" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.PostCode" Label="Postcode" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.State" Label="State" Variant="Variant.Outlined"></MudTextField>
        <MudTextField @bind-Value="client.Country" Label="Country" Variant="Variant.Outlined"></MudTextField>
        <MudNumericField @bind-Value="client.ReminderIntervalDays" Label="Reminder Interval (Days)" Variant="Variant.Outlined" Min="0"></MudNumericField>
        <div class="d-flex align-center gap-2 mt-2">
            <MudSelect @key="paymentTerms.Count"
                       Value="client.PaymentTerm"
                       T="PaymentTerm"
                       Label="Payment Term"
                       Placeholder="Select Payment Term"
                       ValueChanged="OnPaymentTermChanged"
                       Variant="Variant.Outlined"
                       Style="flex: 1;">
                @foreach (var pt in paymentTerms)
                {
                    <MudSelectItem Value="pt">@pt.PaymentTermName</MudSelectItem>
                }
            </MudSelect>
            <MudTooltip Text="Add new payment term">
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="OpenCreatePaymentTermDialogAsync" />
            </MudTooltip>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSave" Class="px-10">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private Client client = new();
    private List<PaymentTerm> paymentTerms = [];

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var _Response = await api.GetPaymentTermsAsync();
        paymentTerms = _Response.PaymentTerms ?? [];
    }

    private void OnPaymentTermChanged(PaymentTerm paymentTerm)
    {
        client.PaymentTerm = paymentTerm;
        client.PaymentTermID = paymentTerm?.PaymentTermID;
    }

    private async Task OpenCreatePaymentTermDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddPaymentTermDialog>();
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is not null)
        {
            var newPaymentTerm = (PaymentTerm)result.Data;
            paymentTerms.Add(newPaymentTerm);
            client.PaymentTerm = newPaymentTerm;
            client.PaymentTermID = newPaymentTerm.PaymentTermID;
            StateHasChanged();
        }
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(client.ClientName))
        {
            Snackbar.Add("Client must have a name.", Severity.Error);
            return;
        }
        var _Request = mapper.Map<CreateClientRequest>(client);
        var _Response = await api.CreateClientAsync(_Request);
        if (!_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        client.ClientID = Newtonsoft.Json.JsonConvert.DeserializeObject<CreateClientResponse>(await _Response.Content.ReadAsStringAsync())!.ClientID;
        Snackbar.Add("Client Created.", Severity.Success);
        MudDialog.Close(DialogResult.Ok(client));
    }
}
