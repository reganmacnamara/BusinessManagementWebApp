@page "/clients"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Clients.DeleteClient
@using MacsBusinessManagementWebApp.Data.Entities
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Clients</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="d-flex align-center mb-6">
        <div>
            <MudText Typo="Typo.h5" Class="page-title">Clients</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage your client accounts</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2">
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedClients.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="OpenCreateClientDialogAsync"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Client</MudButton>
        </MudStack>
    </div>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #EFF6FF;">
                        <MudIcon Icon="@Icons.Material.Filled.People" Style="color: #3B82F6; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Total Clients</MudText>
                        <MudText Typo="Typo.h4" Class="stat-value">@clients.Count</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedClients"
                     Breakpoint="Breakpoint.Sm"
                     Items="@clients"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     RowClass="cursor-pointer"
                     RowClick="ClientSelected"
                     SelectOnRowClick="false"
                     T="Client">
            <Columns>
                <SelectColumn T="Client" />
                <PropertyColumn Property="x => x.ClientName" Title="Name" />
                <PropertyColumn Property="x => x.ClientPhone" Title="Phone" />
                <PropertyColumn Property="x => x.ClientEmail" Title="Email" />
                <PropertyColumn Property="x => x.ClientMobile" Title="Mobile" />
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<AddClientDialog />

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedClients.Count > 1
                ? $"{selectedClients.Count} Clients"
                : $"{selectedClients.First().ClientName}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private List<Client> clients = [];
    private string deleteState = string.Empty;
    private MudMessageBox deleteConfirmationMessage = default!;
    private bool loading;
    private HashSet<Client> selectedClients = [];

    private void ClientSelected(DataGridRowClickEventArgs<Client> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/clients/{args.Item.ClientID}");
    }

    private async Task GetClients()
    {
        loading = true;
        var _Response = await api.GetClientsAsync();
        clients = _Response.Clients ?? [];
        loading = false;
        this.StateHasChanged();
    }

    private async Task OnDelete()
    {
        if (selectedClients.Count != 0)
        {
            int clientsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var client in selectedClients)
                {
                    var _Response = await api.DeleteClientAsync(client.ClientID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        clients.Remove(client);
                        clientsDeleted++;
                    }
                    else
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                }
            }

            if (clientsDeleted > 0)
                Snackbar.Add($"{clientsDeleted} Clients Deleted.", Severity.Warning);

            await GetClients();
            StateHasChanged();
        }
    }

    private async Task OpenCreateClientDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddClientDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            clients.Add((Client)result.Data);
            await GetClients();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetClients();
}
