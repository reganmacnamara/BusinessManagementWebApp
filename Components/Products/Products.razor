@page "/products"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using BusinessManagementWebApp.Data
@using BusinessManagementWebApp.Data.Entities
@using BusinessManagementWebApp.Data.Products.DeleteProduct
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Products</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="d-flex align-center mb-6">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A;">Products</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage your product catalogue and stock</MudText>
        </div>
        <MudSpacer />
        <MudStack Row="true" Spacing="2">
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedProducts.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="OpenCreateProductDialogAsync"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Product</MudButton>
        </MudStack>
    </div>

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Total Products</MudText>
                    <div class="stat-icon-wrap" style="background: #F5F3FF;">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="color: #8B5CF6; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #0F172A; line-height: 1;">@products.Count</MudText>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.caption" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #64748B;">Low Stock</MudText>
                    <div class="stat-icon-wrap" style="background: #FEF2F2;">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color: #EF4444; font-size: 1.2rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #0F172A; line-height: 1;">@products.Count(x => x.QuantityOnHand <= 5)</MudText>
                <MudText Typo="Typo.caption" Style="color: #94A3B8; margin-top: 4px;">5 or fewer in stock</MudText>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedProducts"
                     Breakpoint="Breakpoint.Sm"
                     Items="@products"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     RowClass="cursor-pointer"
                     RowClick="ProductSelected"
                     SelectOnRowClick="false"
                     T="Product">
            <Columns>
                <SelectColumn T="Product" />
                <PropertyColumn Property="x => x.ProductCode" Title="Code" />
                <PropertyColumn Property="x => x.ProductName" Title="Name" />
                <PropertyColumn Property="x => x.ProductDescription" Title="Description" />
                <PropertyColumn Property="x => x.UnitPrice" Title="Unit Price" Format="C" />
                <TemplateColumn Title="Stock">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.QuantityOnHand <= 5 ? Color.Error : Color.Success)"
                                 Variant="Variant.Filled">
                            @context.Item.QuantityOnHand
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<AddProductDialog />

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedProducts.Count > 1
                ? $"{selectedProducts.Count} Products"
                : $"{selectedProducts.First().ProductName}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private string deleteState = string.Empty;
    private MudMessageBox deleteConfirmationMessage = default!;
    private bool loading;
    private List<Product> products = [];
    private HashSet<Product> selectedProducts = [];

    private async Task GetProducts()
    {
        loading = true;
        var _Response = await api.GetProductsAsync();
        products = _Response.Products ?? [];
        loading = false;
        this.StateHasChanged();
    }

    private async Task OnDelete()
    {
        if (selectedProducts.Count != 0)
        {
            int productsDeleted = 0;
            bool? result = await deleteConfirmationMessage.ShowAsync();
            deleteState = result is null ? "Canceled" : "Deleted!";

            if (deleteState == "Deleted!")
            {
                foreach (var product in selectedProducts)
                {
                    var _Response = await api.DeleteProductAsync(product.ProductID);
                    if (_Response.IsSuccessStatusCode)
                    {
                        products.Remove(product);
                        productsDeleted++;
                    }
                    else
                        Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                }
            }

            if (productsDeleted > 0)
                Snackbar.Add($"{productsDeleted} Products Deleted.", Severity.Warning);

            await GetProducts();
            selectedProducts.Clear();
            this.StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetProducts();

    private async Task OpenCreateProductDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddProductDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            products.Add((Product)result.Data);
            await GetProducts();
            StateHasChanged();
        }
    }

    private void ProductSelected(DataGridRowClickEventArgs<Product> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/products/{args.Item.ProductID}");
    }
}
