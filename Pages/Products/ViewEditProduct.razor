@page "/products/{id:long}"
@using System.Text.Json
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities
@using MacsBusinessManagementWebApp.Data.Products.DeleteProduct
@using MacsBusinessManagementWebApp.Data.Products.UpdateProduct

@inject ApiClient api
@inject IJSRuntime JS
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudSkeleton Height="48px" Class="mb-2" Style="border-radius: 8px;" />
        <MudSkeleton Height="20px" Width="40%" Class="mb-6" Style="border-radius: 8px;" />
        <MudSkeleton Height="300px" Style="border-radius: 12px;" />
    </MudContainer>
}
else
{
    <div class="page-header">
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <div class="d-flex align-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack"
                       Class="mr-2"
                       Style="min-width: 0;">Back</MudButton>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" Style="height: 32px; align-self: center;" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">@product.ProductCode — @product.ProductName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Product Details</MudText>
            </div>
            <MudSpacer />
            <MudStack Row="true" Spacing="2">
                <MudButton Color="Color.Primary"
                           OnClick="OnSave"
                           StartIcon="@Icons.Material.Filled.Save"
                           Variant="Variant.Filled"
                           Disabled="@saving">
                    @if (saving)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                    }
                    Save
                </MudButton>
                <MudButton Color="Color.Error"
                           OnClick="OnDelete"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Variant="Variant.Outlined">Delete</MudButton>
            </MudStack>
        </div>
        </MudContainer>
    </div>

    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudPaper Elevation="0" Class="table-card pa-6">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="product.ProductCode"
                                  Label="Code"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Product Code Required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="product.ProductName"
                                  Label="Name"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Product Name Required" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="product.ProductDescription"
                                  Label="Description"
                                  Lines="3"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="product.UnitCost"
                                     Label="Unit Cost"
                                     Format="C"
                                     T="decimal"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="product.UnitPrice"
                                     Label="Unit Price"
                                     Format="C"
                                     T="decimal"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="product.QuantityOnHand"
                                     Label="Quantity on Hand"
                                     T="long"
                                     Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
}

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(product.ProductCode)?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private Product product = default!;
    private bool isLoading = true;
    private bool saving;

    [Parameter]
    public long id { get; set; }

    private async Task GetProductData()
    {
        var _Product = await api.GetProductAsync(id);
        product = _Product.Product;
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void NavigateToProducts()
        => NavigationManager.NavigateTo("products");

    private async Task OnDelete()
    {
        bool? result = await deleteConfirmationMessage.ShowAsync();
        if (result is null) return;

        var _Response = await api.DeleteProductAsync(product.ProductID);
        if (_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"{product.ProductCode} Deleted.", Severity.Warning);
            NavigateToProducts();
        }
        else
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
    }

    protected override async Task OnInitializedAsync()
    {
        await GetProductData();
        isLoading = false;
        StateHasChanged();
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(product.ProductCode))
        {
            Snackbar.Add("Product must have a Code.", Severity.Error);
            return;
        }

        if (string.IsNullOrEmpty(product.ProductName))
        {
            Snackbar.Add("Product must have a Name.", Severity.Error);
            return;
        }

        saving = true;
        try
        {
            var _Request = mapper.Map<UpdateProductRequest>(product);
            var _Response = await api.UpdateProductAsync(_Request);

            if (!_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                return;
            }

            Snackbar.Add("Product Updated.", Severity.Success);
        }
        finally
        {
            saving = false;
        }
    }
}
