@page "/products"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities
@using MacsBusinessManagementWebApp.Data.Products.DeleteProduct
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Products</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="list-header">
        <div>
            <MudText Typo="Typo.h5" Class="page-title">Products</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage your product catalogue and stock</MudText>
        </div>
        <div class="list-header-actions">
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedProducts.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="OpenCreateProductDialogAsync"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Product</MudButton>
        </div>
    </div>

    @if (loadError is not null)
    {
        <PageLoadError Message="@loadError" OnRetry="GetProducts" />
    }

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #F5F3FF;">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="color: #8B5CF6; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Total Products</MudText>
                        <MudText Typo="Typo.h4" Class="stat-value">@products.Count</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #FEF2F2;">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color: #EF4444; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Low Stock</MudText>
                        <MudText Typo="Typo.h4" Class="stat-value">@products.Count(x => x.QuantityOnHand <= 5)</MudText>
                        <MudText Typo="Typo.caption" Style="color: #94A3B8;">5 or fewer in stock</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedProducts"
                     Breakpoint="Breakpoint.Sm"
                     Items="@products"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     QuickFilter="@FilterProduct"
                     RowClass="cursor-pointer"
                     RowClick="ProductSelected"
                     SelectOnRowClick="false"
                     T="Product">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="searchString"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Class="mt-0"
                              IconSize="Size.Medium"
                              Immediate="true"
                              Placeholder="Search..." />
            </ToolBarContent>
            <Columns>
                <SelectColumn T="Product" />
                <PropertyColumn Property="x => x.ProductCode" Title="Code" />
                <PropertyColumn Property="x => x.ProductName" Title="Name" />
                <PropertyColumn Property="x => x.ProductDescription" Title="Description" />
                <PropertyColumn Property="x => x.UnitPrice" Title="Unit Price" Format="C" />
                <TemplateColumn Title="Stock">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.QuantityOnHand <= 5 ? Color.Error : Color.Success)"
                                 Variant="Variant.Filled">
                            @context.Item.QuantityOnHand
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<AddProductDialog />

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedProducts.Count > 1
                ? $"{selectedProducts.Count} Products"
                : $"{selectedProducts.First().ProductName}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private bool loading;
    private string? loadError;
    private List<Product> products = [];
    private string searchString = string.Empty;
    private HashSet<Product> selectedProducts = [];

    private async Task GetProducts()
    {
        loading = true;
        loadError = null;
        try
        {
            var _Response = await api.GetProductsAsync();
            products = _Response.Products ?? [];
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task OnDelete()
    {
        if (selectedProducts.Count == 0) return;

        bool? result = await deleteConfirmationMessage.ShowAsync();
        if (result is null) return;

        int productsDeleted = 0;
        try
        {
            foreach (var product in selectedProducts)
            {
                var _Response = await api.DeleteProductAsync(product.ProductID);
                if (_Response.IsSuccessStatusCode)
                {
                    products.Remove(product);
                    productsDeleted++;
                }
                else
                    Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            }

            if (productsDeleted > 0)
                Snackbar.Add($"{productsDeleted} Product(s) deleted.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An unexpected error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            await GetProducts();
            selectedProducts.Clear();
            StateHasChanged();
        }
    }

    private bool FilterProduct(Product p)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return p.ProductCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || p.ProductName.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || (p.ProductDescription?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    protected override async Task OnInitializedAsync()
        => await GetProducts();

    private async Task OpenCreateProductDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddProductDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            products.Add((Product)result.Data);
            await GetProducts();
            StateHasChanged();
        }
    }

    private void ProductSelected(DataGridRowClickEventArgs<Product> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/products/{args.Item.ProductID}");
    }
}
