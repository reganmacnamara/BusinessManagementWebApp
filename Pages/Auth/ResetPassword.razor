@page "/reset-password"
@layout MacsBusinessManagementWebApp.Components.Layout.EmptyLayout
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Auth.ResetPassword
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api
@inject NavigationManager NavigationManager

<PageTitle>Reset Password - Mac's Business Manager</PageTitle>

<MudThemeProvider Theme="_theme" />

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%); padding: 24px;">
    <MudPaper Elevation="4" Style="width: 100%; max-width: 420px; border-radius: 16px; overflow: hidden;">

        <div style="background: #0F172A; padding: 32px 32px 24px; text-align: center;">
            <MudIcon Icon="@Icons.Material.Filled.Password" Style="font-size: 2.5rem; color: #3B82F6;" />
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #F1F5F9; margin-top: 8px;">
                Set a new password
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 4px;">
                Use the reset code from your email
            </MudText>
        </div>

        <div style="padding: 32px;">
            <MudForm @ref="form">
                <MudTextField @bind-Value="token"
                              Label="Reset code"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.VpnKey"
                              Required="true"
                              RequiredError="Reset code is required"
                              Class="mb-4" />

                <MudTextField @bind-Value="newPassword"
                              Label="New password"
                              Variant="Variant.Outlined"
                              InputType="@(showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="() => showPassword = !showPassword"
                              Required="true"
                              RequiredError="New password is required"
                              Validation="@(new Func<string, string?>(ValidateNewPassword))"
                              Class="mb-4" />

                <MudTextField @bind-Value="confirmPassword"
                              Label="Confirm new password"
                              Variant="Variant.Outlined"
                              InputType="@(showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="() => showPassword = !showPassword"
                              Required="true"
                              RequiredError="Please confirm your new password"
                              Class="mb-4" />

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                        @errorMessage
                    </MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="font-weight: 600; text-transform: none; border-radius: 8px; height: 48px;"
                           Disabled="@isLoading"
                           OnClick="OnSubmit">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                    }
                    Reset Password
                </MudButton>
            </MudForm>

            <MudDivider Class="my-4" />

            <div style="text-align: center;">
                <MudLink Href="/forgot-password"
                         Style="font-weight: 600; display: inline-block; margin-bottom: 12px;">
                    Request a new code
                </MudLink>
                <br />
                <MudLink Href="/login" Style="font-weight: 600;">
                    Return to login
                </MudLink>
            </div>
        </div>
    </MudPaper>
</div>

@code {
    private MudForm form = default!;
    private string token = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading;
    private bool showPassword;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3B82F6",
            PrimaryContrastText = "#FFFFFF",
        }
    };

    protected override void OnInitialized()
    {
        token = GetQueryValue("token") ?? string.Empty;
    }

    private async Task OnSubmit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            ClearPasswordFields();
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var response = await api.ResetPasswordAsync(new ResetPasswordRequest
            {
                Token = token.Trim(),
                NewPassword = newPassword
            });

            if (response.IsSuccessStatusCode)
            {
                var message = Uri.EscapeDataString("Your password has been reset. Please sign in with your new password.");
                NavigationManager.NavigateTo($"/login?message={message}", forceLoad: true);
            }
            else
            {
                errorMessage = await GetResetPasswordError(response);
                ClearPasswordFields();
            }
        }
        catch
        {
            errorMessage = "Unable to reset your password. Please try again.";
            ClearPasswordFields();
        }
        finally
        {
            isLoading = false;
        }
    }

    private static async Task<string> GetResetPasswordError(HttpResponseMessage response)
    {
        return response.StatusCode switch
        {
            System.Net.HttpStatusCode.Unauthorized => "The reset code is invalid or has expired.",
            (System.Net.HttpStatusCode)429 => "Too many reset attempts. Please try again shortly.",
            System.Net.HttpStatusCode.BadRequest => await response.GetErrorBodyAsync(),
            _ => "Unable to reset your password. Please try again."
        };
    }

    private static string? ValidateNewPassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (value.Length < 8)
            return "Password must be at least 8 characters.";

        return null;
    }

    private void ClearPasswordFields()
    {
        newPassword = string.Empty;
        confirmPassword = string.Empty;
    }

    private string? GetQueryValue(string key)
    {
        var query = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).Query;
        if (string.IsNullOrWhiteSpace(query)) return null;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pieces = part.Split('=', 2);
            if (!string.Equals(Uri.UnescapeDataString(pieces[0]), key, StringComparison.OrdinalIgnoreCase)) continue;

            return pieces.Length == 2 ? Uri.UnescapeDataString(pieces[1].Replace("+", " ")) : string.Empty;
        }

        return null;
    }
}
