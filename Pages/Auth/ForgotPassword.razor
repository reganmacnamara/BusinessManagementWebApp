@page "/forgot-password"
@layout MacsBusinessManagementWebApp.Components.Layout.EmptyLayout
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Auth.ForgotPassword
@using MudBlazor
@rendermode InteractiveServer

@inject ApiClient api

<PageTitle>Forgot Password - Mac's Business Manager</PageTitle>

<MudThemeProvider Theme="_theme" />

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%); padding: 24px;">
    <MudPaper Elevation="4" Style="width: 100%; max-width: 420px; border-radius: 16px; overflow: hidden;">

        <div style="background: #0F172A; padding: 32px 32px 24px; text-align: center;">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size: 2.5rem; color: #3B82F6;" />
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #F1F5F9; margin-top: 8px;">
                Reset your password
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #94A3B8; margin-top: 4px;">
                Enter the email address for your account
            </MudText>
        </div>

        <div style="padding: 32px;">
            <MudForm @ref="form">
                <MudTextField @bind-Value="email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new Func<string, string?>(ValidateRequiredEmail))"
                              Disabled="@requestSent"
                              Class="mb-4" />

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
                        @successMessage
                    </MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                        @errorMessage
                    </MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="font-weight: 600; text-transform: none; border-radius: 8px; height: 48px;"
                           Disabled="@(isLoading || requestSent)"
                           OnClick="OnSubmit">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                    }
                    Send Reset Code
                </MudButton>
            </MudForm>

            <MudDivider Class="my-4" />

            <div style="text-align: center;">
                <MudLink Href="/reset-password"
                         Style="font-weight: 600; display: inline-block; margin-bottom: 12px;">
                    I have a reset code
                </MudLink>
                <br />
                <MudLink Href="/login" Style="font-weight: 600;">
                    Return to login
                </MudLink>
            </div>
        </div>
    </MudPaper>
</div>

@code {
    private const string NeutralSuccessMessage = "If an account exists for that email, a reset code has been sent.";

    private MudForm form = default!;
    private string email = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading;
    private bool requestSent;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3B82F6",
            PrimaryContrastText = "#FFFFFF",
        }
    };

    private async Task OnSubmit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        isLoading = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var response = await api.ForgotPasswordAsync(new ForgotPasswordRequest
            {
                Email = email.Trim()
            });

            if (response.IsSuccessStatusCode)
            {
                requestSent = true;
                successMessage = NeutralSuccessMessage;
            }
            else
            {
                errorMessage = GetForgotPasswordError(response);
            }
        }
        catch
        {
            errorMessage = "Unable to send a reset code. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetForgotPasswordError(HttpResponseMessage response)
        => (int)response.StatusCode == 429
            ? "Too many reset requests. Please try again shortly."
            : "Unable to send a reset code. Please try again.";

    private static string? ValidateRequiredEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Email is required.";

        if (!new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(value))
            return "Invalid email address.";

        return null;
    }
}
