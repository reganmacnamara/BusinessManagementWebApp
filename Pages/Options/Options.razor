@page "/options"
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Accounts
@using MacsBusinessManagementWebApp.Data.Companies.UpdateCompany
@using MacsBusinessManagementWebApp.Data.CompanySettings.UpsertCompanySettings
@using MacsBusinessManagementWebApp.Data.Entities
@using MacsBusinessManagementWebApp.Data.PaymentTerms.UpdatePaymentTerm
@using MacsBusinessManagementWebApp.Infrastructure.Services.Auth
@using MudBlazor

@inject ApiClient api
@inject IDialogService DialogService
@inject IMapper mapper
@inject ISnackbar Snackbar
@inject AuthTokenService tokenService
@inject NavigationManager NavigationManager

<PageTitle>Options</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">

    <div class="mb-6">
        <MudText Typo="Typo.h5" Class="page-title">Options</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage your company, payment terms and application defaults</MudText>
    </div>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4"
             Color="Color.Primary" SliderColor="Color.Primary">

        @* ───────── Company Tab ───────── *@
        <MudTabPanel Text="Company" Icon="@Icons.Material.Filled.Business">
            <MudPaper Elevation="0" Class="table-card pa-6">
                @if (companyLoading)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else if (companyLoadError)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                        Unable to load company details. The API may not support this yet.
                    </MudAlert>
                }
                else
                {
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-2">Company Details</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Update your company information that appears on invoices and receipts.</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.CompanyName"
                                          Label="Company Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Company name is required" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.CompanyABN"
                                          Label="ABN"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="ABN is required" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.Email"
                                          Label="Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Email is required"
                                          Validation="@(new Func<string, string?>(ValidateEmail))" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.Phone"
                                          Label="Phone"
                                          Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.AddressLine1"
                                          Label="Address Line 1"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="company.AddressLine2"
                                          Label="Address Line 2"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="company.State"
                                          Label="State"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="company.PostCode"
                                          Label="Postcode"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="company.Country"
                                          Label="Country"
                                          Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-end">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveCompany"
                                       Disabled="@companySaving">
                                @if (companySaving)
                                {
                                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                }
                                Save Changes
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                }
            </MudPaper>
        </MudTabPanel>

        @* ───────── Accounts Tab ───────── *@
        <MudTabPanel Text="Security" Icon="@Icons.Material.Filled.Security">
            <MudPaper Elevation="0" Class="table-card pa-6">
                <MudForm @ref="securityForm">
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-2">Change Password</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                Update the password for your signed-in account.
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="currentPassword"
                                          Label="Current password"
                                          Variant="Variant.Outlined"
                                          InputType="@(showSecurityPasswords ? InputType.Text : InputType.Password)"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(showSecurityPasswords ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                          OnAdornmentClick="() => showSecurityPasswords = !showSecurityPasswords"
                                          Required="true"
                                          RequiredError="Current password is required" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="newPassword"
                                          Label="New password"
                                          Variant="Variant.Outlined"
                                          InputType="@(showSecurityPasswords ? InputType.Text : InputType.Password)"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(showSecurityPasswords ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                          OnAdornmentClick="() => showSecurityPasswords = !showSecurityPasswords"
                                          Required="true"
                                          RequiredError="New password is required"
                                          Validation="@(new Func<string, string?>(ValidateNewPassword))" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="confirmNewPassword"
                                          Label="Confirm new password"
                                          Variant="Variant.Outlined"
                                          InputType="@(showSecurityPasswords ? InputType.Text : InputType.Password)"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(showSecurityPasswords ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                          OnAdornmentClick="() => showSecurityPasswords = !showSecurityPasswords"
                                          Required="true"
                                          RequiredError="Please confirm your new password" />
                        </MudItem>

                        @if (!string.IsNullOrWhiteSpace(passwordChangeError))
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Error" Dense="true">
                                    @passwordChangeError
                                </MudAlert>
                            </MudItem>
                        }

                        <MudItem xs="12" Class="d-flex justify-end">
                            <MudStack Row="true" Spacing="2">
                                <MudButton Color="Color.Default"
                                           Variant="Variant.Text"
                                           StartIcon="@Icons.Material.Filled.Close"
                                           OnClick="ClearPasswordChangeForm"
                                           Disabled="@passwordChanging">
                                    Cancel
                                </MudButton>
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="ChangePassword"
                                           Disabled="@passwordChanging">
                                    @if (passwordChanging)
                                    {
                                        <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                    }
                                    Save Password
                                </MudButton>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudForm>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Accounts" Icon="@Icons.Material.Filled.ManageAccounts">
            <MudPaper Elevation="0" Class="table-card">
                <div class="d-flex align-center pa-4" style="border-bottom: 1px solid #E2E8F0;">
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Accounts</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Create and manage logins that can access this company.</MudText>
                    </div>
                    <MudSpacer />
                    <MudTooltip Text="Refresh accounts">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Color="Color.Primary"
                                       OnClick="LoadAccounts"
                                       Disabled="@accountsLoading" />
                    </MudTooltip>
                </div>

                <div class="pa-4" style="border-bottom: 1px solid #E2E8F0;">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="addAccountEmail"
                                          Label="New account email"
                                          Placeholder="teammate@example.com"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          HelperText="Creates a new login with access to this company."
                                          Error="@(!string.IsNullOrWhiteSpace(addAccountError))"
                                          ErrorText="@addAccountError"
                                          Validation="@(new Func<string, string?>(ValidateEmail))" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="addAccountPassword"
                                          Label="Temporary password"
                                          InputType="InputType.Password"
                                          Variant="Variant.Outlined"
                                          Immediate="true"
                                          Error="@(!string.IsNullOrWhiteSpace(addAccountPasswordError))"
                                          ErrorText="@addAccountPasswordError" />
                        </MudItem>
                        <MudItem xs="12" md="3" Class="d-flex justify-end">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="AddAccount"
                                       Disabled="@accountAdding">
                                @if (accountAdding)
                                {
                                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                }
                                Add Account
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                    @if (!string.IsNullOrWhiteSpace(addAccountFormError))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">
                            @addAccountFormError
                        </MudAlert>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(accountActionMessage))
                {
                    <MudAlert Severity="@accountActionSeverity" Dense="true" Class="ma-4">
                        @accountActionMessage
                    </MudAlert>
                }

                @if (accountsLoadError)
                {
                    <MudAlert Severity="Severity.Warning" Class="ma-4">
                        Unable to load company accounts.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@accounts"
                              Hover="true"
                              Dense="true"
                              Loading="@accountsLoading"
                              Breakpoint="Breakpoint.Sm"
                              Class="account-table">
                        <HeaderContent>
                            <MudTh>Email</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh>Last Login</MudTh>
                            <MudTh Style="width: 150px; text-align: right;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Email">
                                @if (IsEditingAccount(context))
                                {
                                    <MudTextField @bind-Value="editingAccount.Email"
                                                  Label="Email"
                                                  InputType="InputType.Email"
                                                  Variant="Variant.Outlined"
                                                  Immediate="true"
                                                  Error="@(!string.IsNullOrWhiteSpace(editAccountError))"
                                                  ErrorText="@editAccountError"
                                                  Validation="@(new Func<string, string?>(ValidateEmail))" />
                                }
                                else
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText>@context.Email</MudText>
                                        @if (IsCurrentAccount(context))
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">You</MudChip>
                                        }
                                    </MudStack>
                                }
                            </MudTd>
                            <MudTd DataLabel="Status">
                                @if (IsEditingAccount(context))
                                {
                                    <MudSwitch @bind-Value="editingAccount.IsActive"
                                               Color="Color.Primary"
                                               Label="Active"
                                               Disabled="@IsCurrentAccount(context)" />
                                }
                                else
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(context.IsActive ? Color.Success : Color.Default)"
                                             Variant="Variant.Filled">
                                        @(context.IsActive ? "Active" : "Inactive")
                                    </MudChip>
                                }
                            </MudTd>
                            <MudTd DataLabel="Created">@FormatDate(context.CreatedDate)</MudTd>
                            <MudTd DataLabel="Last Login">@FormatDate(context.LastLoginDate)</MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                @if (IsEditingAccount(context))
                                {
                                    <MudTooltip Text="Save account">
                                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                                       Color="Color.Primary"
                                                       OnClick="SaveAccount"
                                                       Disabled="@accountUpdating" />
                                    </MudTooltip>
                                    <MudTooltip Text="Cancel edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Color="Color.Default"
                                                       OnClick="CancelAccountEdit"
                                                       Disabled="@accountUpdating" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Edit account">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => BeginAccountEdit(context))"
                                                       Disabled="@(accountEditing || accountsLoading)" />
                                    </MudTooltip>
                                    <MudTooltip Text="@GetRemoveAccountTooltip(context)">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       OnClick="@(() => ConfirmRemoveAccount(context))"
                                                       Disabled="@(!CanRemoveAccount(context) || accountRemoving)" />
                                    </MudTooltip>
                                }
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Class="pa-4" Color="Color.Secondary">No company accounts found.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                }
            </MudPaper>
        </MudTabPanel>

        @* ───────── Payment Terms Tab ───────── *@
        <MudTabPanel Text="Payment Terms" Icon="@Icons.Material.Filled.Schedule">
            <MudPaper Elevation="0" Class="table-card">
                <div class="d-flex align-center pa-4" style="border-bottom: 1px solid #E2E8F0;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Payment Terms</MudText>
                    <MudSpacer />
                    <MudStack Row="true" Spacing="2">
                        <MudButton Color="Color.Error"
                                   Disabled="@(!selectedTerms.Any())"
                                   OnClick="OnDeleteTerms"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Variant="Variant.Outlined"
                                   Size="Size.Small">Delete</MudButton>
                        <MudButton Color="Color.Primary"
                                   OnClick="OpenCreateTermDialogAsync"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Variant="Variant.Filled"
                                   Size="Size.Small">New Term</MudButton>
                    </MudStack>
                </div>
                <MudDataGrid @bind-SelectedItems="selectedTerms"
                             Breakpoint="Breakpoint.Sm"
                             Items="@paymentTerms"
                             Hover="true"
                             Loading="@termsLoading"
                             LoadingProgressColor="Color.Primary"
                             MultiSelection="true"
                             SelectOnRowClick="false"
                             CommittedItemChanges="OnTermEdited"
                             EditMode="DataGridEditMode.Cell"
                             EditTrigger="DataGridEditTrigger.OnRowClick"
                             ReadOnly="false"
                             T="PaymentTerm">
                    <Columns>
                        <SelectColumn T="PaymentTerm" />
                        <PropertyColumn Property="x => x.PaymentTermName" Title="Name" />
                        <PropertyColumn Property="x => x.Days" Title="Days" />
                        <PropertyColumn Property="x => x.Months" Title="Months" />
                        <TemplateColumn Title="End of Month" Editable="false">
                            <CellTemplate>
                                <MudCheckBox T="bool" Value="context.Item.EndOfMonth"
                                             ValueChanged="(val) => ToggleEndOfMonth(context.Item, val)"
                                             Color="Color.Primary" Dense="true" />
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.DayOfMonth" Title="Day of Month" />
                        <TemplateColumn Title="Offset First" Editable="false">
                            <CellTemplate>
                                <MudCheckBox T="bool" Value="context.Item.OffsetFirst"
                                             ValueChanged="(val) => ToggleOffsetFirst(context.Item, val)"
                                             Color="Color.Primary" Dense="true" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            </MudPaper>
        </MudTabPanel>

        @* ───────── Defaults Tab ───────── *@
        <MudTabPanel Text="Defaults" Icon="@Icons.Material.Filled.Tune">
            <MudPaper Elevation="0" Class="table-card pa-6">
                @if (settingsLoading)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else
                {
                    <MudGrid Spacing="3">
                        @* Invoice Defaults *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-1">Invoice Reference</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Set a prefix and enable auto-increment to automatically generate invoice references.
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="companySettings.InvoicePrefix"
                                          Label="Invoice Prefix"
                                          Placeholder="e.g. INV-"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="companySettings.NextInvoiceNumber"
                                             Label="Next Number"
                                             Variant="Variant.Outlined"
                                             Min="1" />
                        </MudItem>
                        <MudItem xs="12" sm="4" Class="d-flex align-center">
                            <MudSwitch @bind-Value="companySettings.AutoIncrementInvoice"
                                       Color="Color.Primary"
                                       Label="Auto-Increment" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true" NoIcon="false" Class="mb-2">
                                Preview: <strong>@GetInvoicePreview()</strong>
                            </MudAlert>
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                        </MudItem>

                        @* Receipt Defaults *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-1">Receipt Reference</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                Set a prefix and enable auto-increment to automatically generate receipt references.
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="companySettings.ReceiptPrefix"
                                          Label="Receipt Prefix"
                                          Placeholder="e.g. REC-"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="companySettings.NextReceiptNumber"
                                             Label="Next Number"
                                             Variant="Variant.Outlined"
                                             Min="1" />
                        </MudItem>
                        <MudItem xs="12" sm="4" Class="d-flex align-center">
                            <MudSwitch @bind-Value="companySettings.AutoIncrementReceipt"
                                       Color="Color.Primary"
                                       Label="Auto-Increment" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true" NoIcon="false" Class="mb-2">
                                Preview: <strong>@GetReceiptPreview()</strong>
                            </MudAlert>
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-end">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveSettings"
                                       Disabled="@settingsSaving">
                                @if (settingsSaving)
                                {
                                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" />
                                }
                                Save Defaults
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                }
            </MudPaper>
        </MudTabPanel>

    </MudTabs>

</MudContainer>

<MudMessageBox @ref="removeAccountConfirmationMessage"
               Title="Remove account"
               CancelText="Cancel">
    <MessageContent>
        Remove @accountToRemove?.Email from this company?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.PersonRemove">Remove</MudButton>
    </YesButton>
</MudMessageBox>

@* Delete confirmation for payment terms *@
<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedTerms.Count > 1
                ? $"{selectedTerms.Count} Payment Terms"
                : $"{selectedTerms.First().PaymentTermName}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {

    #region Company

    private Company company = new();
    private bool companyLoading = true;
    private bool companyLoadError;
    private bool companySaving;

    private async Task LoadCompany()
    {
        companyLoading = true;
        try
        {
            var response = await api.GetCompanyAsync();
            company = response.Company ?? new();
        }
        catch
        {
            companyLoadError = true;
        }
        finally
        {
            companyLoading = false;
        }
    }

    private async Task SaveCompany()
    {
        if (string.IsNullOrWhiteSpace(company.CompanyName))
        {
            Snackbar.Add("Company name is required.", Severity.Error);
            return;
        }

        companySaving = true;
        try
        {
            var request = mapper.Map<UpdateCompanyRequest>(company);
            var response = await api.UpdateCompanyAsync(request);

            if (response.IsSuccessStatusCode)
                Snackbar.Add("Company details saved.", Severity.Success);
            else
                Snackbar.Add($"Error {(int)response.StatusCode}: {await response.GetErrorBodyAsync()}", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Unable to save company details.", Severity.Error);
        }
        finally
        {
            companySaving = false;
        }
    }

    private static string? ValidateEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (!new System.ComponentModel.DataAnnotations.EmailAddressAttribute().IsValid(value))
            return "Invalid email address.";

        return null;
    }

    #endregion

    #region Security

    private MudForm securityForm = default!;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmNewPassword = string.Empty;
    private string? passwordChangeError;
    private bool passwordChanging;
    private bool showSecurityPasswords;

    private async Task ChangePassword()
    {
        await securityForm.Validate();
        if (!securityForm.IsValid) return;

        passwordChangeError = ValidatePasswordChange();
        if (passwordChangeError is not null) return;

        passwordChanging = true;

        try
        {
            var response = await api.UpdatePasswordAsync(new UpdatePasswordRequest
            {
                CurrentPassword = currentPassword,
                NewPassword = newPassword
            });

            if (response.IsSuccessStatusCode)
            {
                ClearPasswordChangeForm();
                tokenService.ClearToken();

                var message = Uri.EscapeDataString("Your password has been changed. Please sign in again.");
                NavigationManager.NavigateTo($"/login?message={message}", forceLoad: true);
            }
            else
            {
                passwordChangeError = await GetPasswordChangeError(response);
                ClearPasswordFields();
            }
        }
        catch
        {
            passwordChangeError = "Unable to change your password. Please try again.";
            ClearPasswordFields();
        }
        finally
        {
            passwordChanging = false;
        }
    }

    private string? ValidatePasswordChange()
    {
        if (newPassword != confirmNewPassword)
            return "Passwords do not match.";

        if (currentPassword == newPassword)
            return "New password must be different from your current password.";

        return null;
    }

    private static async Task<string> GetPasswordChangeError(HttpResponseMessage response)
    {
        return response.StatusCode switch
        {
            System.Net.HttpStatusCode.Unauthorized => "The current password is incorrect.",
            System.Net.HttpStatusCode.TooManyRequests => "Too many attempts. Please try again shortly.",
            System.Net.HttpStatusCode.BadRequest => await response.GetErrorBodyAsync(),
            _ => "Unable to change your password. Please try again."
        };
    }

    private static string? ValidateNewPassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (value.Length < 8)
            return "Password must be at least 8 characters.";

        return null;
    }

    private void ClearPasswordChangeForm()
    {
        passwordChangeError = null;
        ClearPasswordFields();
    }

    private void ClearPasswordFields()
    {
        currentPassword = string.Empty;
        newPassword = string.Empty;
        confirmNewPassword = string.Empty;
    }

    #endregion

    #region Accounts

    private MudMessageBox removeAccountConfirmationMessage = default!;
    private List<CompanyAccount> accounts = [];
    private CompanyAccount editingAccount = new();
    private CompanyAccount? accountToRemove;
    private string addAccountEmail = string.Empty;
    private string addAccountPassword = string.Empty;
    private string? addAccountError;
    private string? addAccountPasswordError;
    private string? addAccountFormError;
    private string? editAccountError;
    private string? accountActionMessage;
    private Severity accountActionSeverity = Severity.Info;
    private bool accountsLoading = true;
    private bool accountsLoadError;
    private bool accountAdding;
    private bool accountEditing;
    private bool accountUpdating;
    private bool accountRemoving;
    private long editingAccountID;

    private async Task LoadAccounts()
    {
        accountsLoading = true;
        accountsLoadError = false;

        try
        {
            var response = await api.GetAccountsAsync();
            accounts = response.Accounts ?? [];
        }
        catch
        {
            accounts = [];
            accountsLoadError = true;
        }
        finally
        {
            accountsLoading = false;
        }
    }

    private async Task AddAccount()
    {
        addAccountError = ValidateRequiredEmail(addAccountEmail);
        addAccountPasswordError = ValidatePassword(addAccountPassword);
        addAccountFormError = null;
        if (addAccountError is not null || addAccountPasswordError is not null) return;

        accountAdding = true;
        accountActionMessage = null;

        try
        {
            var response = await api.AddAccountAsync(new AddAccountRequest
            {
                Email = addAccountEmail.Trim(),
                Password = addAccountPassword
            });

            if (response.IsSuccessStatusCode)
            {
                addAccountEmail = string.Empty;
                addAccountPassword = string.Empty;
                addAccountError = null;
                addAccountPasswordError = null;
                addAccountFormError = null;
                SetAccountMessage("Account added.", Severity.Success);
                await LoadAccounts();
            }
            else
            {
                addAccountFormError = await response.GetErrorBodyAsync();
            }
        }
        catch
        {
            addAccountFormError = "Unable to add account.";
        }
        finally
        {
            accountAdding = false;
        }
    }

    private async Task BeginAccountEdit(CompanyAccount account)
    {
        accountEditing = true;
        editAccountError = null;
        accountActionMessage = null;

        try
        {
            var latest = await api.GetAccountAsync(account.AccountID);
            editingAccountID = latest.AccountID;
            editingAccount = new CompanyAccount
            {
                AccountID = latest.AccountID,
                Email = latest.Email,
                IsActive = latest.IsActive,
                CreatedDate = latest.CreatedDate,
                LastLoginDate = latest.LastLoginDate
            };
        }
        catch
        {
            SetAccountMessage("Unable to load the latest account details.", Severity.Error);
            accountEditing = false;
            editingAccountID = 0;
        }
    }

    private async Task SaveAccount()
    {
        editAccountError = ValidateRequiredEmail(editingAccount.Email);
        if (editAccountError is not null) return;

        accountUpdating = true;

        try
        {
            var response = await api.UpdateAccountAsync(new UpdateAccountRequest
            {
                AccountID = editingAccount.AccountID,
                Email = editingAccount.Email.Trim(),
                IsActive = editingAccount.IsActive
            });

            if (response.IsSuccessStatusCode)
            {
                CancelAccountEdit();
                SetAccountMessage("Account updated.", Severity.Success);
                await LoadAccounts();
            }
            else
            {
                editAccountError = await response.GetErrorBodyAsync();
            }
        }
        catch
        {
            editAccountError = "Unable to update account.";
        }
        finally
        {
            accountUpdating = false;
        }
    }

    private void CancelAccountEdit()
    {
        accountEditing = false;
        editingAccountID = 0;
        editingAccount = new();
        editAccountError = null;
    }

    private async Task ConfirmRemoveAccount(CompanyAccount account)
    {
        if (!CanRemoveAccount(account)) return;

        accountToRemove = account;
        var result = await removeAccountConfirmationMessage.ShowAsync();
        if (result is null)
        {
            accountToRemove = null;
            return;
        }

        await RemoveAccount(account);
        accountToRemove = null;
    }

    private async Task RemoveAccount(CompanyAccount account)
    {
        accountRemoving = true;
        accountActionMessage = null;

        try
        {
            var response = await api.RemoveAccountAsync(account.AccountID);
            if (response.IsSuccessStatusCode)
            {
                SetAccountMessage("Account removed.", Severity.Success);
                await LoadAccounts();
            }
            else
            {
                SetAccountMessage(await response.GetErrorBodyAsync(), Severity.Error);
            }
        }
        catch
        {
            SetAccountMessage("Unable to remove account.", Severity.Error);
        }
        finally
        {
            accountRemoving = false;
        }
    }

    private bool IsEditingAccount(CompanyAccount account)
        => editingAccountID == account.AccountID;

    private bool IsCurrentAccount(CompanyAccount account)
        => account.AccountID == tokenService.AccountID;

    private bool CanRemoveAccount(CompanyAccount account)
        => !IsCurrentAccount(account) && accounts.Count > 1;

    private string GetRemoveAccountTooltip(CompanyAccount account)
    {
        if (IsCurrentAccount(account))
            return "You cannot remove your own account";

        if (accounts.Count <= 1)
            return "The company must keep at least one account";

        return "Remove account";
    }

    private void SetAccountMessage(string message, Severity severity)
    {
        accountActionMessage = message;
        accountActionSeverity = severity;
    }

    private static string? ValidateRequiredEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Email is required.";

        return ValidateEmail(value);
    }

    private static string? ValidatePassword(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Password is required.";

        if (value.Length < 8)
            return "Password must be at least 8 characters.";

        return null;
    }

    private static string FormatDate(DateTime value)
        => value == default ? "-" : value.ToLocalTime().ToString("dd MMM yyyy h:mm tt");

    private static string FormatDate(DateTime? value)
        => value.HasValue ? FormatDate(value.Value) : "-";

    #endregion

    #region Payment Terms

    private MudMessageBox deleteConfirmationMessage = default!;
    private bool termsLoading;
    private List<PaymentTerm> paymentTerms = [];
    private HashSet<PaymentTerm> selectedTerms = [];

    private async Task LoadPaymentTerms()
    {
        termsLoading = true;
        var response = await api.GetPaymentTermsAsync();
        paymentTerms = response.PaymentTerms ?? [];
        termsLoading = false;
    }

    private async Task OnDeleteTerms()
    {
        if (selectedTerms.Count == 0) return;

        int deleted = 0;
        bool? result = await deleteConfirmationMessage.ShowAsync();
        if (result is null) return;

        foreach (var term in selectedTerms)
        {
            var response = await api.DeletePaymentTermAsync(term.PaymentTermID);
            if (response.IsSuccessStatusCode)
            {
                paymentTerms.Remove(term);
                deleted++;
            }
            else
                Snackbar.Add($"Error {(int)response.StatusCode}: {await response.GetErrorBodyAsync()}", Severity.Error);
        }

        if (deleted > 0)
            Snackbar.Add($"{deleted} Payment Term(s) deleted.", Severity.Warning);

        await LoadPaymentTerms();
        selectedTerms.Clear();
        StateHasChanged();
    }

    private async Task OpenCreateTermDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<MacsBusinessManagementWebApp.Components.PaymentTerms.AddPaymentTermDialog>();
        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            paymentTerms.Add((PaymentTerm)result.Data);
            await LoadPaymentTerms();
            StateHasChanged();
        }
    }

    private async Task OnTermEdited(PaymentTerm term)
    {
        var request = mapper.Map<UpdatePaymentTermRequest>(term);
        var response = await api.UpdatePaymentTermAsync(request);

        if (response.IsSuccessStatusCode)
            Snackbar.Add("Payment term updated.", Severity.Success);
        else
            Snackbar.Add($"Error {(int)response.StatusCode}: {await response.GetErrorBodyAsync()}", Severity.Error);
    }

    private async Task ToggleEndOfMonth(PaymentTerm term, bool value)
    {
        term.EndOfMonth = value;
        await OnTermEdited(term);
        StateHasChanged();
    }

    private async Task ToggleOffsetFirst(PaymentTerm term, bool value)
    {
        term.OffsetFirst = value;
        await OnTermEdited(term);
        StateHasChanged();
    }

    #endregion

    #region Defaults

    private Data.Entities.CompanySettings companySettings = new();
    private bool settingsLoading = true;
    private bool settingsSaving;

    private async Task LoadSettings()
    {
        settingsLoading = true;
        try
        {
            var response = await api.GetCompanySettingsAsync();
            companySettings = response.CompanySettings ?? new();
        }
        catch
        {
            companySettings = new();
        }
        finally
        {
            settingsLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        settingsSaving = true;
        try
        {
            var request = mapper.Map<UpsertCompanySettingsRequest>(companySettings);
            var response = await api.UpsertCompanySettingsAsync(request);

            if (response.IsSuccessStatusCode)
                Snackbar.Add("Defaults saved.", Severity.Success);
            else
                Snackbar.Add($"Error {(int)response.StatusCode}: {await response.GetErrorBodyAsync()}", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Unable to save defaults.", Severity.Error);
        }
        finally
        {
            settingsSaving = false;
        }
    }

    private string GetInvoicePreview()
    {
        var prefix = companySettings.InvoicePrefix;
        if (companySettings.AutoIncrementInvoice)
            return $"{prefix}{companySettings.NextInvoiceNumber:D4}";
        return string.IsNullOrEmpty(prefix) ? "(no prefix set)" : prefix;
    }

    private string GetReceiptPreview()
    {
        var prefix = companySettings.ReceiptPrefix;
        if (companySettings.AutoIncrementReceipt)
            return $"{prefix}{companySettings.NextReceiptNumber:D4}";
        return string.IsNullOrEmpty(prefix) ? "(no prefix set)" : prefix;
    }

    #endregion

    protected override async Task OnInitializedAsync()
    {
        var companyTask = LoadCompany();
        var accountsTask = LoadAccounts();
        var termsTask = LoadPaymentTerms();
        var settingsTask = LoadSettings();

        await Task.WhenAll(companyTask, accountsTask, termsTask, settingsTask);
        StateHasChanged();
    }
}
