@page "/receipts"
@using System.Text.Json
@using System.Threading.Tasks
@using AutoMapper
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities

@inject ApiClient api
@inject IJSRuntime JS
@inject IMapper mapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Receipts</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

    <div class="list-header">
        <div>
            <MudText Typo="Typo.h5" Class="page-title">Receipts</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track all payments received from clients</MudText>
        </div>
        <div class="list-header-actions">
            <MudButton Color="Color.Info"
                       Disabled="@(!selectedReceipts.Any())"
                       OnClick="ExportSelectedPdfs"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       Variant="Variant.Outlined">Export PDF</MudButton>
            <MudButton Color="Color.Error"
                       Disabled="@(!selectedReceipts.Any())"
                       OnClick="OnDelete"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Variant="Variant.Outlined">Delete</MudButton>
            <MudButton Color="Color.Primary"
                       OnClick="NavigateToCreateReceipt"
                       StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Filled">New Receipt</MudButton>
        </div>
    </div>

    @if (loadError is not null)
    {
        <PageLoadError Message="@loadError" OnRetry="GetTransactionsDataAsync" />
    }

    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #EFF6FF;">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Style="color: #3B82F6; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Total Receipts</MudText>
                        <MudText Typo="Typo.h4" Class="stat-value">@receipts.Count</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #ECFDF5;">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color: #10B981; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Total Received</MudText>
                        <MudText Typo="Typo.h5" Class="stat-value">@receipts.Sum(x => x.NetValue).ToString("C")</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="stat-card">
                <div class="d-flex align-center" style="gap: 16px;">
                    <div class="stat-icon-wrap stat-icon-wrap--lg" style="background: #FFFBEB;">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="color: #F59E0B; font-size: 1.5rem;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Class="stat-label">Unallocated</MudText>
                        <MudText Typo="Typo.h5" Class="stat-value">@receipts.Sum(x => Math.Max(0m, x.NetValue - x.OffsetValue)).ToString("C")</MudText>
                    </div>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="table-card">
        <MudDataGrid @bind-SelectedItems="selectedReceipts"
                     Breakpoint="Breakpoint.Sm"
                     Items="receipts"
                     Hover="true"
                     Loading="@loading"
                     LoadingProgressColor="Color.Primary"
                     MultiSelection="true"
                     QuickFilter="@FilterReceipt"
                     RowClass="cursor-pointer"
                     RowClick="TransactionSelected"
                     SelectOnRowClick="false"
                     T="Receipt">
            <ToolBarContent>
                <MudToggleGroup @bind-Value="statusFilter" T="string?" Color="Color.Primary" Outline="true" Rounded="true" Class="ml-2">
                    <MudToggleItem Value="@((string?)null)">All</MudToggleItem>
                    <MudToggleItem Value="@("unallocated")">Unallocated</MudToggleItem>
                    <MudToggleItem Value="@("allocated")">Allocated</MudToggleItem>
                </MudToggleGroup>
                <MudSpacer />
                <MudTextField @bind-Value="searchString"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Class="mt-0"
                              IconSize="Size.Medium"
                              Immediate="true"
                              Placeholder="Search..." />
            </ToolBarContent>
            <Columns>
                <SelectColumn T="Receipt" />
                <PropertyColumn Property="x => x.ReceiptDate" Title="Date" Format="dd/MM/yyyy" />
                <PropertyColumn Property="x => x.ReceiptRef" Title="Reference" />
                <PropertyColumn Property="x => x.Client.ClientName" Title="Client" />
                <PropertyColumn Property="x => x.NetValue" Title="Net Value" Format="C" />
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.Outstanding ? Color.Warning : Color.Success)"
                                 Variant="Variant.Filled">
                            @(context.Item.Outstanding ? "Unallocated" : "Allocated")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => Math.Max(0m, x.NetValue - x.OffsetValue)" Title="Outstanding Amt." Format="C" />
            </Columns>
        </MudDataGrid>
    </MudPaper>

</MudContainer>

<MudMessageBox @ref="deleteConfirmationMessage"
               Title="Warning"
               CancelText="Cancel">
    <MessageContent>
        Are you sure you want to delete @(selectedReceipts.Count > 1
                ? $"{selectedReceipts.Count} Receipts"
                : $"{selectedReceipts.First().ReceiptRef}")?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    private MudMessageBox deleteConfirmationMessage = default!;
    private bool loading;
    private string? loadError;
    private string searchString = string.Empty;
    private string? statusFilter = null;
    HashSet<Receipt> selectedReceipts = [];
    List<Receipt> receipts = [];

    private bool FilterReceipt(Receipt r)
    {
        var matchesSearch = string.IsNullOrWhiteSpace(searchString)
            || r.ReceiptRef.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || (r.Client?.ClientName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

        var matchesStatus = statusFilter is null
            || (statusFilter == "unallocated" && r.Outstanding)
            || (statusFilter == "allocated" && !r.Outstanding);

        return matchesSearch && matchesStatus;
    }

    private async Task GetTransactionsDataAsync()
    {
        loading = true;
        loadError = null;
        try
        {
            var _Response = await api.GetReceiptsAsync();
            receipts = _Response.Receipts ?? [];
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportSelectedPdfs()
    {
        foreach (var receipt in selectedReceipts)
        {
            var _Response = await api.ExportReceiptPdfAsync(receipt.ReceiptID);
            if (!_Response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Error exporting {receipt.ReceiptRef}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
                continue;
            }
            var bytes = await _Response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadPdf", $"Receipt_{receipt.ReceiptRef}.pdf", bytes);
        }
    }

    private void NavigateToCreateReceipt()
        => NavigationManager.NavigateTo($"/receipts/create");

    private async Task OnDelete()
    {
        if (selectedReceipts.Count == 0) return;

        bool? result = await deleteConfirmationMessage.ShowAsync();
        if (result is null) return;

        int transactionsDeleted = 0;
        try
        {
            foreach (var transaction in selectedReceipts)
            {
                var _Response = await api.DeleteReceiptAsync(transaction.ReceiptID);
                if (_Response.IsSuccessStatusCode)
                {
                    receipts.Remove(transaction);
                    transactionsDeleted++;
                }
                else
                    Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            }

            if (transactionsDeleted > 0)
                Snackbar.Add($"{transactionsDeleted} Receipt(s) deleted.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An unexpected error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            selectedReceipts.Clear();
            await GetTransactionsDataAsync();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
        => await GetTransactionsDataAsync();

    private void TransactionSelected(DataGridRowClickEventArgs<Receipt> args)
    {
        if (args.Item is not null)
            NavigationManager.NavigateTo($"/receipts/{args.Item.ReceiptID}");
    }
}
