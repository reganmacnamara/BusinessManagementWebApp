@page "/receipts/create"
@using System.Text.Json
@using AutoMapper
@using MacsBusinessManagementWebApp.Components.Clients
@using MacsBusinessManagementWebApp.Data
@using MacsBusinessManagementWebApp.Data.Entities
@using MacsBusinessManagementWebApp.Data.Receipts.CreateReceipt
@using MacsBusinessManagementWebApp.Data.Receipts.UpsertReceiptItem
@using MacsBusinessManagementWebApp.Infrastructure.Services.Settings

@inject ApiClient api
@inject IJSRuntime JS
@inject IMapper mapper
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject UserSettingsService settingsService

<PageTitle>New Receipt</PageTitle>

<div class="page-header">
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <div class="d-flex align-center">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack"
                       Class="mr-2"
                       Style="min-width: 0;">Back</MudButton>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" Style="height: 32px; align-self: center;" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">New Receipt</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Record a new client payment</MudText>
            </div>
            <MudSpacer />
            <MudButton Color="Color.Primary"
                       OnClick="OnSave"
                       StartIcon="@Icons.Material.Filled.Save"
                       Variant="Variant.Filled">Save</MudButton>
        </div>
    </MudContainer>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">

        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
            <MudPaper Elevation="0" Class="table-card pa-6">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="receipt.ReceiptRef"
                                      Label="Receipt Reference"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Receipt Reference Required" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Date="receipt.ReceiptDate"
                                        DateChanged="OnReceiptDateChanged"
                                       Format="dd/MM/yyyy"
                                       Label="Receipt Date"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="10" sm="5">
                        <MudSelect @key="clients.Count"
                                   Value="receipt.Client"
                                   T="Client"
                                   Label="Client"
                                   Placeholder="Select Client"
                                   ValueChanged="OnClientChanged"
                                   Variant="Variant.Outlined">
                            @foreach (var client in clients)
                            {
                                <MudSelectItem Value="client">@client.ClientName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="2" sm="1" Class="d-flex align-self-end">
                        <MudTooltip Text="Add new client">
                            <MudIconButton Icon="@Icons.Material.Filled.PersonAdd"
                                           Color="Color.Primary"
                                           OnClick="OpenCreateClientDialogAsync" />
                        </MudTooltip>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField Format="C"
                                         Label="Gross Value"
                                         T="decimal"
                                         Value="receipt.GrossValue"
                                         ValueChanged="OnGrossValueChanged"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField Format="C"
                                         Label="Tax Value"
                                         T="decimal"
                                         Value="receipt.TaxValue"
                                         ValueChanged="OnTaxValueChanged"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField Format="C"
                                         Label="Net Value"
                                         T="decimal"
                                         Value="receipt.NetValue"
                                         ValueChanged="OnNetValueChanged"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Allocations"
                     Icon="@Icons.Material.Filled.AccountBalanceWallet"
                     Disabled="receipt.Client is null">
            <MudPaper Elevation="0" Class="table-card">
                <div class="d-flex align-center pa-3" style="border-bottom: 1px solid #E2E8F0;">
                    <MudButton Color="Color.Primary"
                               OnClick="OpenCreateReceiptItemDialogAsync"
                               StartIcon="@Icons.Material.Filled.Add"
                               Variant="Variant.Filled"
                               Size="Size.Small">Add Item</MudButton>
                    <MudButton Color="Color.Error"
                               OnClick="DeleteReceiptItems"
                               StartIcon="@Icons.Material.Filled.Delete"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               Class="ml-2"
                               Disabled="@(!selectedReceiptItems.Any())">Remove</MudButton>
                    <MudSpacer />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mr-2">Un-Allocated:</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@Math.Max(0m, receipt.NetValue - receipt.OffsetValue).ToString("C")</MudText>
                </div>
                <MudDataGrid @bind-SelectedItems="selectedReceiptItems"
                             Breakpoint="Breakpoint.Sm"
                             Items="receiptItems"
                             EditMode="DataGridEditMode.Cell"
                             EditTrigger="DataGridEditTrigger.OnRowClick"
                             MultiSelection="true"
                             ReadOnly="false"
                             SelectOnRowClick="false"
                             T="ReceiptItem">
                    <Columns>
                        <SelectColumn T="ReceiptItem" />
                        <PropertyColumn Editable="false" Property="x => x.Invoice.InvoiceRef" Title="Ref" />
                        <PropertyColumn Editable="false" Property="x => x.Invoice.InvoiceDate" Title="Date" Format="dd/MM/yyyy" />
                        <PropertyColumn Editable="false" Property="x => x.Invoice.NetValue" Title="Net" Format="C" />
                        <TemplateColumn Editable="false" Title="Outstanding Amt.">
                            <CellTemplate>
                                @GetInvoiceOutstandingAfterAllocation(context.Item).ToString("C")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Editable="true" Title="Allocated">
                            <CellTemplate>
                                @context.Item.NetValue.ToString("C")
                            </CellTemplate>
                            <EditTemplate>
                                <MudNumericField Format="C"
                                                 Value="context.Item.NetValue"
                                                 ValueChanged="(value) => OnAllocationUpdated(value, context.Item)"
                                                 T="decimal" />
                            </EditTemplate>
                        </TemplateColumn>
                        <TemplateColumn>
                            <CellTemplate>
                                <MudStack Row="true">
                                    <MudButton Color="Color.Success"
                                               OnClick="() => CompleteAllocation(context.Item)"
                                               Size="Size.Small"
                                               Variant="Variant.Filled">
                                        Allocate
                                    </MudButton>
                                    <MudButton Color="Color.Warning"
                                               OnClick="() => ClearAllocation(context.Item)"
                                               Size="Size.Small"
                                               Variant="Variant.Filled">
                                        De-Allocate
                                    </MudButton>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            </MudPaper>
        </MudTabPanel>

    </MudTabs>
</MudContainer>

<AddClientDialog />
<AddReceiptAllocationDialog />

@code {
    private List<Client> clients = [];
    private List<Invoice> clientInvoices = [];
    private HashSet<ReceiptItem> selectedReceiptItems = [];
    private Receipt receipt = new();
    private List<ReceiptItem> receiptItems = [];

    private void ClearAllocation(ReceiptItem allocation)
    {
        allocation.NetValue = 0;
        RecalculateOffsets();
        StateHasChanged();
    }

    private void CompleteAllocation(ReceiptItem allocation)
    {
        var invoiceRemaining = GetInvoiceAvailableBeforeAllocation(allocation);
        var receiptAvailable = receipt.NetValue - receipt.OffsetValue + allocation.NetValue;
        allocation.NetValue = Math.Min(invoiceRemaining, receiptAvailable);
        RecalculateOffsets();
        StateHasChanged();
    }

    private async Task DeleteReceiptItems()
    {
        if (!selectedReceiptItems.Any())
            return;

        foreach (var _Item in selectedReceiptItems)
            receiptItems.Remove(_Item);

        selectedReceiptItems.Clear();
        RecalculateOffsets();
        StateHasChanged();
    }

    private async Task GetClients()
    {
        var _Response = await api.GetClientsAsync();
        clients = _Response.Clients ?? [];
        StateHasChanged();
    }

    private async Task GetClientInvoices()
    {
        var _Response = await api.GetClientInvoicesAsync(receipt.Client.ClientID);
        clientInvoices = _Response.Invoices.Where(t => t.Outstanding == true).ToList() ?? [];
        StateHasChanged();
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void NavigateToReceipts()
        => NavigationManager.NavigateTo("receipts");

    protected override async Task OnInitializedAsync()
    {
        await GetClients();

        var generatedRef = await settingsService.GenerateReceiptRefAsync();
        if (!string.IsNullOrEmpty(generatedRef))
            receipt.ReceiptRef = generatedRef;
    }

    private void OnAllocationUpdated(decimal value, ReceiptItem item)
    {
        var invoiceRemaining = GetInvoiceAvailableBeforeAllocation(item);
        var receiptAvailable = receipt.NetValue - receipt.OffsetValue + item.NetValue;
        var maxAllowable = Math.Min(invoiceRemaining, receiptAvailable);
        if (value >= 0 && value <= maxAllowable)
        {
            item.NetValue = value;
            RecalculateOffsets();
            StateHasChanged();
        }
    }

    private async Task OnReceiptDateChanged(DateTime? dateTime)
    {
        if (!dateTime.HasValue)
            return;

        receipt.ReceiptDate = dateTime.Value;
    }

    private async Task OnSave()
    {
        if (string.IsNullOrEmpty(receipt.ReceiptRef))
        {
            Snackbar.Add("Receipt must have a reference.", Severity.Error);
            return;
        }

        if (receipt.Client is null)
        {
            Snackbar.Add("Receipt must have a client.", Severity.Error);
            return;
        }

        if (receiptItems.Count == 0)
        {
            Snackbar.Add("Receipt must have at least one item.", Severity.Error);
            return;
        }

        RecalculateOffsets();
        if (receipt.OffsetValue > receipt.NetValue)
        {
            Snackbar.Add("Receipt allocations cannot exceed the receipt net value.", Severity.Error);
            return;
        }

        receipt.Outstanding = receipt.OffsetValue < receipt.NetValue;

        var _Request = mapper.Map<CreateReceiptRequest>(receipt);
        _Request.ReceiptItems = receiptItems
            .Select(mapper.Map<UpsertReceiptItemRequest>)
            .ToList();

        var _Response = await api.CreateReceiptAsync(_Request);

        if (!_Response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Error {(int)_Response.StatusCode}: {await _Response.GetErrorBodyAsync()}", Severity.Error);
            return;
        }

        await settingsService.IncrementReceiptNumberAsync();
        Snackbar.Add("Receipt Created.", Severity.Success);
        NavigateToReceipts();
    }

    private async Task OpenCreateClientDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddClientDialog>();
        var result = await dialog.Result;

        if (dialog.Result is not null && !dialog.Result.IsCanceled && result is not null && result.Data is not null)
        {
            SelectCreatedClient((Client)result.Data);
            await GetClients();
            StateHasChanged();
        }
    }

    private async Task OnClientChanged(Client client)
    {
        if (receipt.ClientID != 0 && receipt.ClientID != client.ClientID)
        {
            receiptItems.Clear();
            selectedReceiptItems.Clear();
            RecalculateOffsets();
        }

        receipt.Client = client;
        receipt.ClientID = client.ClientID;
        await GetClientInvoices();
    }

    private void OnGrossValueChanged(decimal value)
    {
        receipt.GrossValue = value;
        receipt.TaxValue = value * 0.1m;
        receipt.NetValue = receipt.GrossValue + receipt.TaxValue;
    }

    private void OnNetValueChanged(decimal value)
    {
        receipt.NetValue = value;
        receipt.GrossValue = receipt.NetValue / 1.1m;
        receipt.TaxValue = receipt.GrossValue * 0.1m;
    }

    private void OnTaxValueChanged(decimal value)
    {
        receipt.TaxValue = value;
        receipt.GrossValue = receipt.TaxValue * 10;
        receipt.NetValue = receipt.GrossValue + receipt.TaxValue;
    }

    private async Task OpenCreateReceiptItemDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<AddReceiptAllocationDialog>("", new DialogParameters<AddReceiptAllocationDialog>()
        {
            { x => x.ClientID, receipt.ClientID }
        });

        var result = await dialog.Result;

        if (!dialog.Result.IsCanceled && result?.Data is not null)
        {
            foreach (var _Allocation in (HashSet<ReceiptItem>)result.Data)
            {
                if (receiptItems.Any(item => item.InvoiceID == _Allocation.InvoiceID))
                {
                    Snackbar.Add($"{_Allocation.Invoice.InvoiceRef} is already allocated on this receipt.", Severity.Info);
                    continue;
                }

                receiptItems.Add(_Allocation);
            }

            RecalculateOffsets();
            StateHasChanged();
        }
    }

    private void RecalculateOffsets()
        => receipt.OffsetValue = receiptItems.Sum(a => a.NetValue);

    private decimal GetInvoiceAvailableBeforeAllocation(ReceiptItem item)
        => Math.Max(0m, GetInvoiceEditableCapacity(item) - GetOtherAllocationsForInvoice(item));

    private decimal GetInvoiceOutstandingAfterAllocation(ReceiptItem item)
        => Math.Max(0m, GetInvoiceEditableCapacity(item) - GetCurrentAllocationsForInvoice(item.InvoiceID));

    private decimal GetInvoiceEditableCapacity(ReceiptItem item)
        => Math.Max(0m, item.Invoice.NetValue - item.Invoice.OffsetValue);

    private decimal GetCurrentAllocationsForInvoice(long invoiceID)
        => receiptItems
            .Where(item => item.InvoiceID == invoiceID)
            .Sum(item => item.NetValue);

    private decimal GetOtherAllocationsForInvoice(ReceiptItem item)
        => receiptItems
            .Where(allocation => !ReferenceEquals(allocation, item) && allocation.InvoiceID == item.InvoiceID)
            .Sum(allocation => allocation.NetValue);

    private void SelectCreatedClient(Client client)
    {
        clients.Add(client);
        receipt.Client = client;
        receipt.ClientID = client.ClientID;
        StateHasChanged();
    }
}
